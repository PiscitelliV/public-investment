              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Status of the CUP having complete and system-validated information. This requires completing all mandatory fields, including financial data and location. All this information is public, except for that relating to the user who requested the code.</lexicalForm>
                <datatype>None</datatype>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
