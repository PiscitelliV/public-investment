              <object>
                <lexicalForm>Service, Office, Management, Department of the Entity responsible for the project to which the reference user who interacts with the CUP System belongs.</lexicalForm>
                <datatype>None</datatype>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
