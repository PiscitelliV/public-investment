        <iri>
          <value>https://w3id.org/italia/onto/OpenCUP/Storia_di_cup</value>
          <annotations>
            <annotation>
              <subject>https://w3id.org/italia/onto/OpenCUP/Storia_di_cup</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Storia di cup</lexicalForm>
                <datatype>None</datatype>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/onto/OpenCUP/Storia_di_cup</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>History of cup</lexicalForm>
                <datatype>None</datatype>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/onto/OpenCUP/Storia_di_cup</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Registro cronologico e immutabile di tutte le variazioni, integrazioni e passaggi di stato che hanno interessato un determinato CUP dalla sua generazione fino alla chiusura o revoca. Tiene traccia di ogni evento, dell'operatore che lo genera e del momento in cui viene generato.</lexicalForm>
                <datatype>None</datatype>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/onto/OpenCUP/Storia_di_cup</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>A chronological and immutable log of all changes, additions, and status changes affecting a given CUP from its generation until its closure or revocation. It tracks each event, the operator that generated it, and the time it occurred.</lexicalForm>
                <datatype>None</datatype>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
