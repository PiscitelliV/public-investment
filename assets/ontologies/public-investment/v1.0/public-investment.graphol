              <object>
                <lexicalForm>Servizio, Ufficio, Direzione, Dipartimento del Soggetto responsabile del progetto cui appartiene l’utente di riferimento che interagisce con il Sistema CUP.</lexicalForm>
                <datatype>None</datatype>
