            <annotation>
              <subject>https://w3id.org/italia/onto/OpenCUP/Utente_richiedente_cup</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>User requesting cup</lexicalForm>
                <datatype>None</datatype>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/onto/OpenCUP/Utente_richiedente_cup</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Persona fisica, immutabile nel tempo, che si è registrata al sistema come utente generatore e che ha richiesto il CUP. Può far capo ad un Soggetto responsabile (Soggetto Titolare) o ad un Soggetto concentratore.</lexicalForm>
                <datatype>None</datatype>
                <language>it</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://w3id.org/italia/onto/OpenCUP/Utente_richiedente_cup</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>A natural person, unchangeable over time, who has registered in the system as a generating user and has requested a CUP. This person may be a Responsible Entity (Controller Entity) or a Concentrator Entity.</lexicalForm>
                <datatype>None</datatype>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://w3id.org/italia/onto/OpenCUP/Utente_riferimento_cup</value>
