}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_di_beni",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A public investment project by a public entity for the purchase of \"durable\" goods (hospital equipment, offices, or furniture for administrative offices), with the entity itself paying the costs requested by the seller; the CUP is requested by the entity owning the project. (CIPE Resolution No. 63/2020)."
  }, {
    "@language" : "it",
    "@value" : "Progetto di investimento pubblico di un ente pubblico per l’acquisto di beni «durevoli» (macchinari di un ospedale, sedi o arredi per uffici amministrativi) con il pagamento, da parte dell’ente medesimo, dei costi richiesti dal venditore; il CUP è richiesto dall’ente titolare del progetto. (Delibera CIPE n. 63/2020)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Acquisto di beni"
  }, {
    "@language" : "en",
    "@value" : "Purchase of goods"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid31"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid27"
  }, {
    "@id" : "_:genid30"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_o_realizzazione_altro_servizio",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Sottoclasse di Acquisto o realizzazione di servizi, residuale rispetto ai corsi di formazione e ai progetti di ricerca."
  }, {
    "@language" : "en",
    "@value" : "Subclass of Purchase or realization of services, residual with respect to training courses and research projects."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Acquisto o realizzazione altro servizio"
  }, {
    "@language" : "en",
    "@value" : "Purchase or provision of another service"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid44"
  }, {
    "@id" : "_:genid45"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid32"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_o_realizzazione_corso_di_formazione",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Sottoclasse di Acquisto o realizzazione di servizi, relativa ai corsi di formazione."
  }, {
    "@language" : "en",
    "@value" : "Subclass of Purchase or provision of services, relating to training courses."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Acquisto o realizzazione corso di formazione"
  }, {
    "@language" : "en",
    "@value" : "Purchase or completion of a training course"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid56"
  }, {
    "@id" : "_:genid57"
  }, {
    "@id" : "_:genid58"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid46"
  }, {
    "@id" : "_:genid55"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_o_realizzazione_di_servizi",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Progetto di investimento pubblico di un ente pubblico (richiedente il CUP) per:  \r\n-l’acquisto di servizi di sviluppo (un progetto di ricerca, l’adeguamento di un software, un corso di formazione) con il pagamento, da parte dell’ente, dei costi richiesti dal venditore; \r\n-la realizzazione di servizi di sviluppo (un progetto di ricerca, l’adeguamento di un software, un corso di formazione) con il pagamento, da parte dell’ente, dei costi connessi alle attività realizzative; rientrano in questa casistica i servizi di progettazione di opere pubbliche, se tali attività sono definite in relazione a un quadro economico di spesa specifico, distinto dalla realizzazione dell’opera. (Delibera CIPE n. 63/2020)."
  }, {
    "@language" : "en",
    "@value" : "Public investment project by a public entity (applicant for the CUP) for:\r\n- the purchase of development services (a research project, software upgrades, a training course) with the entity paying the costs requested by the vendor;\r\n- the implementation of development services (a research project, software upgrades, a training course) with the entity paying the costs associated with the implementation activities; this category includes public works design services, if such activities are defined in relation to a specific economic expenditure framework, distinct from the construction of the work. (CIPE Resolution No. 63/2020)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Acquisto o realizzazione di servizi"
  }, {
    "@language" : "en",
    "@value" : "Purchase or provision of services"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid59"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_o_realizzazione_progetto_di_ricerca",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Sottoclasse di Acquisto o realizzazione di servizi, relativa ai progetti di ricerca."
  }, {
    "@language" : "en",
    "@value" : "Subclass of Purchase or provision of services, relating to research projects."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Acquisto o realizzazione progetto di ricerca"
  }, {
    "@language" : "en",
    "@value" : "Purchase or implementation of research project"
  }, {
    "@value" : "Acquisto o realizzazione progetto di ricerca"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid74"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid64"
  }, {
    "@id" : "_:genid73"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_o_realizzazione_studio_o_progettazione",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Sottoclasse di Acquisto o realizzazione di servizi che identifica le attività preliminari di studio o progettazione tecnica di un'opera, esclusivamente nell'ambito della Natura 3 \"Realizzazione di lavori pubblici (opera ed impiantistica)\" laddove sia collegata alla Natura 2 per la tipologia \"Studi e progettazione\". I servizi di progettazione possono essere acquisiti da fornitori esterni tramite procedure di gara, oppure possono essere svolti internamente all'amministrazione da parte della struttura organizzativa competente."
  }, {
    "@language" : "en",
    "@value" : "Subclass of Purchase or provision of services identifies the preliminary study or technical design activities for a project, exclusively within the scope of Nature 3 \"Public works (construction and systems)\" where it is linked to Nature 2 for the \"Studies and design\" typology. Design services may be acquired from external suppliers through tender procedures, or they may be performed internally by the administration by the competent organizational structure."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Acquisto o realizzazione studio o progettazione"
  }, {
    "@language" : "en",
    "@value" : "Purchase or implementation of study or design"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid75"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Area_di_intervento",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Lista a scelta singola contenente le aree d’intervento compatibilmente alla Natura selezionata, relativa ai metadati di OpenCUP. Individua le categorie omogenee con cui è possibile descrivere \"l'oggetto progettuale\" (n. 6 aree – Classificazione con relativi codici):\r\n01 – Immobili\r\n02 – Trasporti\r\n03 – Ambiente ed energia\r\n04 – Aree produttive\r\n05 – Ricerca, ITC, formazione ed altro\r\n06 – Servizi per la P.A. e per la collettività."
  }, {
    "@language" : "en",
    "@value" : "Single-choice list containing the areas of intervention compatible with the selected Nature, relative to the OpenCUP metadata. Identify the homogeneous categories with which to describe the \"project object\" (6 areas – Classification with related codes):\r\n01 – Real Estate\r\n02 – Transportation\r\n03 – Environment and Energy\r\n04 – Production Areas\r\n05 – Research, ICT, Training and Other\r\n06 – Services for the Public Administration and the Community."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Area di intervento"
  }, {
    "@language" : "en",
    "@value" : "Area of ​​intervention"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Any expression of will capable of producing legal effects."
  }, {
    "@language" : "it",
    "@value" : "Qualsiasi manifestazione di volontà capace di produrre effetti giuridici."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Act"
  }, {
    "@language" : "it",
    "@value" : "Atto"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid84"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_amministrativo_progetto_cumulativo",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Administrative provision adopted by the public administration responsible for the public investment project concerning a complex of interventions consisting of the granting of contributions to entities that are not production units, by which multiple projects or beneficiaries are jointly regulated and approved."
  }, {
    "@language" : "it",
    "@value" : "Provvedimento amministrativo adottato dalla pubblica amministrazione responsabile del progetto di investimento pubblico avente ad oggetto un complesso di interventi consistenti nella concessione di contributi a soggetti che non sono unità produttive, con il quale vengono disciplinati e approvati congiuntamente più progetti o beneficiari."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Administrative act cumulative project"
  }, {
    "@language" : "it",
    "@value" : "Atto amministrativo progetto cumulativo"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_autorizzazione_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Administrative provision formalizing the decision to implement a public investment project, constituting the legal basis for requesting the code. It identifies the decision-maker, the allocated resources, and the scope of the project. The details (date and protocol) of the project must be entered into the system to ensure document and accounting traceability."
  }, {
    "@language" : "it",
    "@value" : "Provvedimento amministrativo che formalizza la decisione di realizzare un Progetto d'investimento pubblico, costituendo il presupposto giuridico per la richiesta del codice. Esso identifica il decisore, le risorse stanziate e l'oggetto dell'intervento, i cui estremi (data e protocollo) devono essere inseriti nel sistema per garantirne la tracciabilità documentale e contabile."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Atto autorizzazione cup"
  }, {
    "@language" : "en",
    "@value" : "CUP Authorization Act"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_cancellazione_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Corrective action performed exclusively to eliminate a code generated due to a material error. Unlike revocation, this action invalidates the CUP from the outset, provided there are no other related projects or technical constraints preventing its logical removal from the system."
  }, {
    "@language" : "it",
    "@value" : "Operazione correttiva effettuata esclusivamente per eliminare un codice generato per errore materiale. A differenza della revoca, essa annulla la validità del CUP fin dall'origine, a patto che non vi siano altri progetti collegati o vincoli tecnici che ne impediscano la rimozione logica dal sistema."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Atto cancellazione cup"
  }, {
    "@language" : "en",
    "@value" : "CUP Cancellation Act"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid85"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_chiusura_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Operazione che identifica lo stato finale del ciclo di vita di un CUP e formalizza la conclusione definitiva di un Progetto d'investimento pubblico nel sistema di monitoraggio. Può essere adottato solo quando l'intervento è ultimato fisicamente, tutti i flussi finanziari (incassi e pagamenti) sono stati perfezionati e l'iter amministrativo è concluso, portando il codice allo stato di \"chiuso\"."
  }, {
    "@language" : "en",
    "@value" : "This operation identifies the final stage of a CUP's life cycle and formalizes the definitive conclusion of a public investment project in the monitoring system. It can only be adopted once the project has been physically completed, all financial flows (receipts and payments) have been finalized, and the administrative process has been concluded, resulting in the code being \"closed.\""
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Atto chiusura cup"
  }, {
    "@language" : "en",
    "@value" : "Cup closing act"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid87"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_delega_richiesta_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Act of the public administration holding the investment and, therefore, responsible for the CUP request by which, on the basis of specific agreements, the delegation of the CUP request is formalized to a suitable authorized public body (so-called \"concentrator\") who will provide evidence of it in the system, without prejudice to the former's responsibilities regarding the obligation to request the CUP assignment and the accuracy of the data entered into the system."
  }, {
    "@language" : "it",
    "@value" : "Atto della pubblica amministrazione titolare dell'investimento e, quindi, responsabile di richiesta cup con il quale, sulla base di specifici accordi, si formalizza la delega della richiesta del CUP ad idoneo soggetto pubblico abilitato (cosiddetto «concentratore») che ne darà evidenza nel sistema, ferme restando le responsabilità del primo per quanto concerne l’obbligo di richiesta di assegnazione del CUP e la correttezza dei dati inseriti nel sistema»."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Atto delega richiesta cup"
  }, {
    "@language" : "en",
    "@value" : "Delegation deed for CUP request"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid89"
  }, {
    "@id" : "_:genid90"
  }, {
    "@id" : "_:genid91"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_finanziamento_investimento_pubblico",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An administrative act, including a regulatory act, adopted by a public administration (Article 1, paragraph 2, Legislative Decree no. 165/2001), which provides for public funding or authorizes the implementation of public investment projects. The same administrative act includes the CUP (which allows for the tracking and monitoring of the project itself) of the authorized projects in the spending program, indicating the funding granted under those measures, the effective date of that funding, and the total value of the individual investments. The act, which may take the form, for example, of a resolution, a management order, a decree, or a measure approving one or more rankings, is null and void in the absence of the corresponding CUP, which constitutes an essential element of the act itself (Article 11 bis, paragraph 2 bis, Law no. 3/2003; CIPE Resolution no. 54 of July 22, 2010)."
  }, {
    "@language" : "it",
    "@value" : "Atto amministrativo anche di natura regolamentare, adottato da una pubblica amministrazione (art. 1, comma 2, d. lgs. n. 165/2001), che dispone il finanziamento pubblico o autorizza l'esecuzione di progetti di investimento pubblico. Nello stesso atto amministrativo, è associato il CUP (che permette di tracciare e monitorare il progetto stesso) dei progetti autorizzati al programma di spesa con l'indicazione dei finanziamenti concessi a valere su dette misure, della data di efficacia di detti finanziamenti e del valore complessivo dei singoli investimenti. L'atto, che si può esplicare, ad esempio, in una delibera, un provvedimento dirigenziale, un decreto, un provvedimento di approvazione di una o più graduatorie, è nullo in assenza del corrispondente CUP che costituisce elemento essenziale dell'atto stesso (art. 11 bis, comma 2 bis, L. n. 3/2003; Delibera CIPE n. 54 del 22 luglio 2010). "
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Atto finanziamento investimento pubblico"
  }, {
    "@language" : "en",
    "@value" : "Public Investment Financing Act"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_generazione_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Procedura telematica di richiesta e rilascio del CUP, obbligatoria per ogni investimento pubblico sin dalla sua approvazione. Esso richiede l'inserimento di un corredo informativo dettagliato (costi, obiettivi, localizzazione) che garantisce la tracciabilità e la validità giuridica del progetto stesso."
  }, {
    "@language" : "en",
    "@value" : "The online procedure for requesting and issuing the CUP is mandatory for all public investments from the moment of approval. It requires the inclusion of detailed information (costs, objectives, location) that ensures the project's traceability and legal validity."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Atto generazione cup"
  }, {
    "@language" : "en",
    "@value" : "Generation Cup Act"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid92"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_modifica_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An administrative and technical procedure that allows updating a project's information to ensure consistency with the evolution of the administrative decision. The operations are divided into:\r\nSimple operations that can be performed independently by the authorized user via the system's \"Edit\" functions:\r\n- Information modification: includes updating the project's descriptive and personal data (e.g., title or description) and/or financial data (e.g., revision of the overall cost and related financing plan) that do not alter the project's fundamental identity.\r\nComplex and assisted operations that require sending a specific request to the Support Structure via the \"Send Change Request\" function:\r\n- Replacement of the CUP: required in the event of radical changes to the project's scope, purpose, or location.\r\n- Split: splitting an original project into two or more independent interventions, each with its own financial framework.\r\n- Merger: consolidating multiple previously separate projects into a single, new, coordinated intervention."
  }, {
    "@language" : "it",
    "@value" : "Procedura amministrativa e tecnica che permette di aggiornare il corredo informativo di un progetto per garantirne la coerenza con l'evoluzione della decisione amministrativa. Le operazioni si dividono in:\r\nOperazioni semplici che sono eseguibili autonomamente dall'utente abilitato tramite le funzioni di \"Modifica\" del sistema:\r\n- Variazione del corredo informativo: include l'aggiornamento dei dati anagrafico-descrittivi (es. titolo o descrizione) e/o dei dati finanziari (es. revisione del costo complessivo e del relativo piano di finanziamento) che non alterano l'identità sostanziale del progetto.\r\nOperazioni complesse e assistite che richiedono l'invio di una specifica istanza alla Struttura di supporto tramite la funzione \"Invio richiesta modifica\":\r\n- Sostituzione del CUP: necessaria in caso di cambiamenti radicali dell'oggetto, della finalità o della localizzazione dell'intervento.\r\n- Scissione: scomposizione di un progetto originale in due o più interventi indipendenti, ciascuno con il proprio quadro economico.\r\n- Fusione: accorpamento di più progetti precedentemente distinti in un unico nuovo intervento coordinato."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Atto modifica cup"
  }, {
    "@language" : "en",
    "@value" : "CUP Amendment Act"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid94"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_revoca_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Operazione che annulla la validità di un codice a seguito di una rinuncia formale alla realizzazione dell’intervento o alla perdita del finanziamento. A differenza della cancellazione, presuppone un progetto originariamente valido la cui esecuzione viene interrotta, richiedendo l'inserimento di una motivazione specifica per giustificare il passaggio del CUP allo stato di \"revocato\".\r\nOperazioni semplici che sono eseguibili autonomamente dall'utente abilitato tramite le funzioni di \"Revoca\" del sistema:\r\n- Revoca del corredo informativo: annullamento del progetto per rinuncia al finanziamento, mancata attivazione dell'intervento o accorpamento in altro progetto (previa motivazione da inserire nel sistema).\r\nOperazioni complesse e assistite che richiedono l'invio di una specifica istanza alla Struttura di supporto:\r\n- Revoca per sostituzione: necessaria quando il CUP deve essere chiuso per far posto a un nuovo codice che identifichi meglio l'evoluzione del progetto.\r\n- Revoca post-collegamento: procedura assistita obbligatoria se il CUP da revocare è già stato associato ad altri codici (es. legami tra progettazione e lavori) o se sono già presenti flussi finanziari tracciati."
  }, {
    "@language" : "en",
    "@value" : "This operation cancels the validity of a code following a formal withdrawal from the project or the loss of funding. Unlike cancellation, it presupposes an originally valid project whose execution is interrupted, requiring the entry of a specific reason to justify the CUP's transition to \"revoked.\"\r\nSimple operations that can be performed independently by an authorized user using the system's \"Revocation\" functions:\r\n- Revocation of the information package: cancellation of the project due to withdrawal from funding, failure to activate the project, or merger with another project (subject to a reason entered in the system).\r\nComplex and assisted operations that require sending a specific request to the Support Structure:\r\n- Revocation for replacement: required when the CUP must be closed to make way for a new code that better identifies the project's evolution.\r\n- Post-link revocation: assisted procedure mandatory if the CUP to be revoked has already been associated with other codes (e.g., links between planning and works) or if traceable financial flows already exist."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Atto revoca cup"
  }, {
    "@language" : "en",
    "@value" : "CUP revocation act"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid96"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_revoca_delega_richiesta_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A measure by which the entity responsible for the investment project formally cancels the digital or operational signature authority on the CUP system granted to a third party. It is divided into:\r\n- Revocation by the Delegate (PF): terminates the technical access of the user responsible for generating the codes.\r\n- Revocation by the Concentrating Entity: dissolves the administrative link between the owner entity and the structure operating on its behalf."
  }, {
    "@language" : "it",
    "@value" : "Provvedimento con cui il Soggetto titolare del progetto d'investimento annulla formalmente il potere di firma digitale o operativa sul sistema CUP concesso a un terzo. Si distingue in:\r\n- Revoca per il Delegato (PF): interrompe l'accesso tecnico dell'utente incaricato alla generazione dei codici.\r\n- Revoca del Soggetto concentratore: scioglie il legame amministrativo tra l'ente titolare e la struttura che operava per suo conto."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Atto revoca delega richiesta cup"
  }, {
    "@language" : "en",
    "@value" : "Revocation of delegation request for CUP"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid98"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Categoria_di_intervento",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "It further specifies the intervention subsector and represents the highest level of detail in the information set. For example, in the case of Sector 01 - Transport Infrastructure, Subsector \"Roads\", we will have the intervention categories \"Motorways\", \"Cycle Paths\", \"State Roads\", \"Regional, Provincial, and Municipal Roads\", \"Rural Roads\", and \"Other Road Structures/Infrastructure\"."
  }, {
    "@language" : "it",
    "@value" : "Specifica ulteriormente il Sottosettore di intervento e ne rappresenta il massimo livello di dettaglio nel corredo informativo. Ad esempio, nel caso di Settore 01 - infrastrutture di trasporto, Sottosettore \"Stradali\", avremo le Categorie di intervento \"Autostrade\", \"Piste ciclabili\", \"Strade statali\", \"Strade regionali, provinciali e comunali\", \"Strade rurali\", \"Altre strutture/Infrastrutture stradali\"."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Categoria di intervento"
  }, {
    "@language" : "en",
    "@value" : "Intervention category"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Codice_unico_di_progetto",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A unique alphanumeric code, consisting of fifteen characters, that identifies each public investment intervention/project. The administrations responsible for implementing these interventions must associate it with the code by requesting its generation in the CUP information system, after being accredited to the system. The CUP makes databases containing information on the implementation status of public investments interoperable. It is included on all administrative and accounting documents, both paper and electronic, relating to public investment projects and must be used in the databases of the various information systems involved in the aforementioned projects (Article 11, paragraph 1, Law No. 3/2003; CIPE Resolution No. 63 of November 26, 2020)."
  }, {
    "@language" : "it",
    "@value" : "Codice alfanumerico univoco, costituito da quindici caratteri, che identifica ciascun intervento/progetto di investimento pubblico, e che deve essere ad esso associato da parte delle amministrazioni titolari, soggetti attuatori, dei medesimi interventi, chiedendone la generazione nel sistema informativo CUP, previo accreditamento allo stesso sistema. Il CUP rende interoperabili le banche dati contenenti informazioni sullo stato di attuazione degli investimenti pubblici È riportato su tutti i documenti amministrativi e contabili, cartacei e informatici, relativi a progetti d’investimento pubblico, e deve essere utilizzato nelle banche dati dei vari sistemi informativi, comunque interessati ai suddetti progetti (art. 11, comma 1, L. n. 3/2003; Delibera CIPE n. 63 del 26 novembre 2020)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Codice unico di progetto"
  }, {
    "@language" : "en",
    "@value" : "Unique project code"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid100"
  }, {
    "@id" : "_:genid101"
  }, {
    "@id" : "_:genid102"
  }, {
    "@id" : "_:genid103"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Concessione_di_contributi_ad_altri_soggetti",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A public investment project consisting of a public entity's decision to assist a private individual in carrying out a development project (repairing a home after a natural disaster, pursuing a training program) with the entity paying part or all of the expected costs; the CUP is requested by the entity."
  }, {
    "@language" : "it",
    "@value" : "Progetto d'investimento pubblico che consiste nella decisione di un ente pubblico di aiutare un privato a realizzare un intervento di sviluppo (riparare un’abitazione dopo una calamità naturale, seguire un percorso formativo) con il pagamento, da parte dell’ente, di una parte o della totalità dei costi previsti; il CUP è richiesto dall’ente."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Concessione di contributi ad altri soggetti"
  }, {
    "@language" : "en",
    "@value" : "Granting of contributions to other entities"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid109"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid105"
  }, {
    "@id" : "_:genid106"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Concessione_di_incentivi_ad_unità_produttive",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A public investment project consisting of a public entity's decision to grant financing to a company for a development project (a new plant, factory maintenance, warehouse expansion), with the entity paying part or all of the company's projected costs; the CUP is requested by the entity."
  }, {
    "@language" : "it",
    "@value" : "Progetto d'investimento pubblico che consiste nella decisione di un ente pubblico di concedere un finanziamento a un’impresa per realizzare un intervento di sviluppo (un nuovo stabilimento, la manutenzione di una fabbrica, l’ampliamento di un magazzino) con il pagamento, da parte dell’ente, di parte - o della totalità - dei costi previsti dall’impresa; il CUP è richiesto dall’ente."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Concessione di incentivi ad unità produttive"
  }, {
    "@language" : "en",
    "@value" : "Granting incentives to production units"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid110"
  }, {
    "@id" : "_:genid111"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Cup_collegato_a_master",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "CUP che identifica progetti fra loro collegati in quanto riferiti/riferibili ad un CUP Master. Permette di distinguere lotti o fasi diverse del progetto, garantendo che tutti i flussi finanziari dei \"figli\" (CUP collegati) siano riconducibili all'investimento unitario del \"padre\" (CUP master)."
  }, {
    "@language" : "en",
    "@value" : "CUP identifies projects that are linked to each other because they are referred to/can be referred to a Master CUP. It allows you to distinguish different lots or phases of the project, ensuring that all the financial flows of the \"children\" (linked CUPs) are traceable to the single investment of the \"parent\" (master CUP)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Cup collegato a master"
  }, {
    "@language" : "en",
    "@value" : "Cup connected to master"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid114"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Cup_cumulativo",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "CUP afferente a molteplici progetti d’investimento pubblico che sono parte di un unico complesso di interventi; il soggetto responsabile può richiedere un CUP cumulativo quando i progetti consistono nella concessione di contributi a soggetti che non sono unità produttive e in presenza di unico provvedimento amministrativo (delibera, provvedimento dirigenziale, decreto, provvedimento di approvazione di una o più graduatorie, e simili) (Delibera CIPE n. 54 del 22 luglio 2010)."
  }, {
    "@language" : "en",
    "@value" : "CUP relating to multiple public investment projects that are part of a single complex of interventions; the responsible entity may request a cumulative CUP when the projects consist of the granting of contributions to entities that are not production units and in the presence of a single administrative provision (resolution, managerial provision, decree, provision approving one or more rankings, and the like) (CIPE Resolution No. 54 of July 22, 2010)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Cumulative Cup"
  }, {
    "@language" : "it",
    "@value" : "Cup cumulativo"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Cup_master",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "CUP di riferimento nel caso di progetti con un livello di complessità realizzativa che richiede l’esecuzione mediante un’articolazione di progetti distinti, ma connessi sotto il profilo logico funzionale o temporale; all’atto della richiesta del CUP per ciascuno di essi, i soggetti responsabili registrano il riferimento al CUP relativo alla prima articolazione inserita nel sistema che, così, assurge a CUP Master del progetto globale. Il CUP Master risulta coincidente, dunque, con il codice del progetto che avvia la fase realizzativa dello schema progettuale globale ed è, pertanto, di norma assegnato, come CUP definitivo, al primo fra i progetti integrati che consegue un finanziamento pubblico, al quale è possibile riconnettere tutti i successivi progetti afferenti quello globale. Il collegamento dei singoli CUP di progetto al CUP Master consente la riconducibilità di tale serie di progetti al progetto complesso e quindi la sommabilità delle informazioni relative ai progetti attuativi ([Delibera CIPE n. 143 del 27 dicembre 2002)."
  }, {
    "@language" : "en",
    "@value" : "Reference CUP for projects with a level of implementation complexity that requires execution through a subdivision of distinct projects, yet connected in terms of logic, function, or time. When requesting a CUP for each project, the responsible parties record the reference to the CUP relating to the first subdivision entered into the system, which thus becomes the Master CUP for the overall project. The Master CUP therefore coincides with the project code that initiates the implementation phase of the overall project plan and is therefore normally assigned, as the definitive CUP, to the first of the integrated projects to receive public funding, to which all subsequent projects pertaining to the overall project can be connected. Linking the individual project CUPs to the Master CUP allows this series of projects to be traced back to the overall project and therefore the summation of information relating to the implementation projects ([CIPE Resolution no. 143 of 27 December 2002)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Cup master"
  }, {
    "@language" : "it",
    "@value" : "Cup master"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid116"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid115"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Delega_parziale",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Modalità di conferimento che riguarda solo casi specifici o ambiti limitati all'interno di una determinata Natura di intervento. A differenza della delega totale, non impedisce al Soggetto responsabile (Soggetto titolare) di continuare a generare autonomamente i codici CUP per i progetti che non rientrano nell'ambito specifico delegato. Un esempio di delega parziale è quello relativo ai soli lavori pubblici realizzati in base a una specifica legge."
  }, {
    "@language" : "en",
    "@value" : "This delegation method concerns only specific cases or limited areas within a given Nature of Intervention. Unlike full delegation, it does not prevent the Responsible Party (Owner) from continuing to independently generate CUP codes for projects that do not fall within the specific delegated scope. An example of partial delegation is one relating only to public works carried out pursuant to a specific law."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Delega parziale"
  }, {
    "@language" : "en",
    "@value" : "Partial delegation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid118"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Delega_totale"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Delega_richiesta_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Conferimento, da parte della pubblica amministrazione titolare dell'investimento (e, quindi, responsabile di richiesta cup) del potere di richiesta del CUP ad idoneo soggetto pubblico abilitato (cosiddetto «concentratore») che ne darà evidenza nel sistema, ferme restando le responsabilità del primo per quanto concerne l’obbligo di richiesta di assegnazione del CUP e la correttezza dei dati inseriti nel sistema. (Delibera CIPE n. 63/2020)."
  }, {
    "@language" : "en",
    "@value" : "The public administration responsible for the investment (and, therefore, responsible for requesting the CUP) will grant the power to request the CUP to a suitable authorized public entity (the \"concentrator\"), which will provide evidence of this in the system. This will remain without prejudice to the former's responsibilities regarding the obligation to request the CUP assignment and the accuracy of the data entered into the system. (CIPE Resolution No. 63/2020)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Delega richiesta cup"
  }, {
    "@language" : "en",
    "@value" : "Delegate cup request"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/italia/onto/TI/TimeIndexedEvent"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid119"
  }, {
    "@id" : "_:genid122"
  }, {
    "@id" : "_:genid123"
  }, {
    "@id" : "_:genid124"
  }, {
    "@id" : "_:genid125"
  }, {
    "@id" : "_:genid126"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Delega_totale",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Modalità di conferimento in cui il Soggetto responsabile (Soggetto titolare) rinuncia completamente alla possibilità di generare autonomamente i codici CUP per la Natura di intervento indicata nella delega. In questo caso, la funzione di richiesta dei codici per quella specifica natura è affidata esclusivamente al Soggetto concentratore fino alla revoca della delega stessa."
  }, {
    "@language" : "en",
    "@value" : "This is a method of assignment in which the Responsible Entity (Owner) completely waives the ability to independently generate CUP codes for the type of intervention indicated in the delegation. In this case, the function of requesting codes for that specific type is entrusted exclusively to the Concentrating Entity until the delegation is revoked."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Delega totale"
  }, {
    "@language" : "en",
    "@value" : "Full delegation"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Intervento_di_investimento_pubblico",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Minimum operational unit of a project, at a functional level it represents the part of the information set relating to the Nature, Typology, Sector, Subsector and Category of the project."
  }, {
    "@language" : "it",
    "@value" : "Unità minima operativa di un progetto, a livello funzionale rappresenta la parte del corredo informativo relativa alla Natura, la Tipologia, il Settore, Il Sottosettore e la Categoria del progetto."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Intervento di investimento pubblico"
  }, {
    "@language" : "en",
    "@value" : "Public investment intervention"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid127"
  }, {
    "@id" : "_:genid134"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Intervento_di_investimento_pubblico_cumulativo",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A collection of multiple investment projects that are part of a single set of interventions that allows for the generation of a single CUP when the projects consist of grants to entities that are not production units and the responsible administration has adopted a single specific administrative provision relating to the set of interventions, such as a resolution, a management provision, a decree, a provision approving one or more rankings, and the like.\r\nThe cumulative CUP cannot, however, be used in all cases where the \"Monit web\" monitoring systems of the State General Accounting Office and the \"Project Management System\" of the Ministry of Economic Development require that each individual intervention be monitored at the individual recipient level. (CIPE Resolution No. 54/2010)."
  }, {
    "@language" : "it",
    "@value" : "Insieme di molteplici progetti d'investimento che fanno parte di un unico complesso di interventi che consente la generazione di un unico CUP qualora i progetti consistono nella concessione di contributi a soggetti che non sono unità produttive e l’amministrazione responsabile ha adottato un unico apposito provvedimento amministrativo, relativo al complesso di interventi, quale ad esempio una delibera, un provvedimento dirigenziale, un decreto, un provvedimento di approvazione di una o più graduatorie, e simili.\r\nIl CUP cumulativo non può comunque essere utilizzato in tutti i casi in cui i sistemi di monitoraggio «Monit web» della Ragioneria generale dello Stato e «Sistema gestione progetti» del Ministero dello sviluppo economico richiedano che ciascun singolo intervento sia monitorato a livello di singolo destinatario. (Delibera Cipe n. 54/2010)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Cumulative public investment intervention"
  }, {
    "@language" : "it",
    "@value" : "Intervento di investimento pubblico cumulativo"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Concessione_di_contributi_ad_altri_soggetti"
  }, {
    "@id" : "_:genid140"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid136"
  }, {
    "@id" : "_:genid137"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Natura_di_intervento",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Classifica il tipo di progetto e le sue modalità di esecuzione e rappresenta nell'ambito dell'intervento il dato gerarchicamente più importante nel sistema. È il primo dei due livelli (natura e tipologia), tutti obbligatori.\r\nLe 6 Nature di intervento presenti nel sistema sono le seguenti:\r\n01 - Acquisto di beni\r\n02 - Acquisto o realizzazione di servizi\r\n03 - Realizzazione di lavori pubblici (opera ed impiantistica)\r\n06 - Concessione di contributi ad altri soggetti\r\n07 - Concessione di incentivi ad unità produttive\r\n08 - Sottoscrizione iniziale o aumento di capitale sociale (compresi spin off), fondi di rischio o di garanzia."
  }, {
    "@language" : "en",
    "@value" : "It classifies the type of project and its implementation methods and represents the most important hierarchical data within the system. It is the first of two levels (nature and typology), both of which are mandatory.\r\nThe 6 types of intervention present in the system are as follows:\r\n01 - Purchase of goods\r\n02 - Purchase or provision of services\r\n03 - Construction of public works (construction and systems)\r\n06 - Granting of contributions to other entities\r\n07 - Granting of incentives to production units\r\n08 - Initial subscription or increase in share capital (including spin-offs), venture or guarantee funds."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Natura di intervento"
  }, {
    "@language" : "en",
    "@value" : "Nature of intervention"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid141"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Norma_di_finanziamento",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An element of the information package that identifies the legislative reference or administrative provision authorizing the disbursement of resources for the project. It allows tracking the use of public funds by linking them to specific laws or programs and is essential for financial reporting and verifying the consistency between allocations and actual commitments. Key components of the financing regulation are the type of regulation, the number and year of publication, and the relevant articles and paragraphs."
  }, {
    "@language" : "it",
    "@value" : "Elemento del corredo informativo che identifica il riferimento legislativo o il provvedimento amministrativo che autorizza l'erogazione delle risorse per il progetto. Permette di tracciare l'utilizzo dei fondi pubblici legandoli a specifiche leggi o programmi ed è essenziale per la rendicontazione finanziaria e per verificare la coerenza tra stanziamenti e impegni reali. Componenti fondamentali della norma di finanziamento sono il tipo di norma, il numero e l'anno di pubblicazione, gli articoli e i comma di riferimento."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Financing standard"
  }, {
    "@language" : "it",
    "@value" : "Norma di finanziamento"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid160"
  }, {
    "@id" : "_:genid161"
  }, {
    "@id" : "_:genid162"
  }, {
    "@id" : "_:genid163"
  }, {
    "@id" : "_:genid164"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Progetto_di_investimento_pubblico",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A set of interconnected actions or support instruments for the implementation of a public investment project consisting of four requirements: 1) the presence of a public decision-maker; 2) financing—even partial, direct, or indirect—with public resources or through the use of public facilities for the project's implementation; 3) the aforementioned actions or instruments have a common objective of economic and social development; 4) to be achieved within a specified timeframe. The Project can be classified according to its nature: public works; granting of incentives; granting of contributions; purchase of goods; purchase or provision of services; capital increases (CIPE Resolutions Nos. 63/2020, 143/2020)."
  }, {
    "@language" : "it",
    "@value" : "Complesso di azioni o di strumenti di sostegno collegati fra loro per la realizzazione di un intervento di investimento pubblico costituito da quattro requisiti: 1) presenza di un decisore pubblico; 2) finanziamento - anche parziale, diretto o indiretto - con risorse pubbliche o con l’uso di strutture pubbliche per la realizzazione del progetto; 3) le azioni o gli strumenti suddetti hanno un comune obiettivo di sviluppo economico e sociale; 4) da raggiungere entro un tempo specificato. Il Progetto può essere classificato in funzione della sua natura: lavori pubblici; concessione incentivi; concessione contributi; acquisto di beni; acquisto o realizzazione di servizi; aumenti di capitale (Delibere CIPE nn. 63/2020, 143/2020). "
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Progetto di investimento pubblico"
  }, {
    "@language" : "en",
    "@value" : "Public investment project"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid165"
  }, {
    "@id" : "_:genid166"
  }, {
    "@id" : "_:genid167"
  }, {
    "@id" : "_:genid168"
  }, {
    "@id" : "_:genid169"
  }, {
    "@id" : "_:genid170"
  }, {
    "@id" : "_:genid171"
  }, {
    "@id" : "_:genid172"
  }, {
    "@id" : "_:genid173"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Realizzazione_di_lavori_pubblici",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A public investment project consisting of a decision by an entity (contracting authority) to commission an infrastructure project (a new road, maintenance of a school, expansion of a hospital), with the contracting authority paying the company or companies that carry it out. The CUP is generally associated with the construction of the functional lot, where applicable; the CUP is requested by the contracting authority."
  }, {
    "@language" : "it",
    "@value" : "Progetto d'investimento pubblico che consiste nella decisione di un ente (stazione appaltante) di far realizzare un intervento infrastrutturale (una nuova strada, la manutenzione di una scuola, l’ampliamento di un ospedale) con il pagamento, da parte della stazione appaltante, della impresa/delle imprese che lo realizzano. Il CUP è generalmente associato alla realizzazione del lotto funzionale ove previsto; il CUP è richiesto dalla stazione appaltante."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Construction of public works"
  }, {
    "@language" : "it",
    "@value" : "Realizzazione di lavori pubblici"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid178"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid174"
  }, {
    "@id" : "_:genid177"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Settore_di_intervento",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Individua le categorie omogenee all'interno delle quali ricomprendere gli interventi in base alla loro destinazione. È il primo dei tre livelli (settore, sottosettore e categoria), tutti obbligatori. Gli 11 settori di intervento presenti nel sistema sono i seguenti:\r\n01 - infrastrutture di trasporto\r\n02 - infrastrutture ambientali e risorse idriche\r\n03 - infrastrutture del settore energetico\r\n04 - infrastrutture per l'attrezzatura di aree produttive\r\n05 - infrastrutture sociali\r\n06 - opere, impianti ed attrezzature per attività produttive, e la ricerca e l'impresa sociale\r\n07 - infrastrutture per telecomunicazioni e tecnologie informatiche\r\n08 - ricerca sviluppo tecnologico ed innovazione\r\n09 - servizi alle imprese\r\n10 - servizi per la p.a. e per la collettività\r\n11 - istruzione, formazione e sostegni per il mercato del lavoro."
  }, {
    "@language" : "en",
    "@value" : "It identifies homogeneous categories within which interventions are classified based on their intended purpose. This is the first of three levels (sector, subsector, and category), all of which are mandatory. The 11 intervention sectors present in the system are as follows:\r\n01 - transport infrastructure\r\n02 - environmental infrastructure and water resources\r\n03 - energy sector infrastructure\r\n04 - infrastructure for the equipment of production areas\r\n05 - social infrastructure\r\n06 - works, facilities, and equipment for production activities, research, and social enterprise\r\n07 - telecommunications and information technology infrastructure\r\n08 - research, technological development, and innovation\r\n09 - business services\r\n10 - public administration and community services\r\n11 - education, training, and labor market support."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Sector of intervention"
  }, {
    "@language" : "it",
    "@value" : "Settore di intervento"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Soggetto_accreditato_sistema_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An entity that has completed the registration and validation process on the CUP System portal. This is necessary to appoint contact persons and enable users to generate codes. The entity accredited in the CUP system acts as the legal entity responsible for the system, ensuring that those operating on behalf of an officially recognized institution."
  }, {
    "@language" : "it",
    "@value" : "Ente che ha completato l'iter di registrazione e validazione presso il portale Sistema CUP. Questa è la condizione necessaria per poter nominare i referenti e abilitare gli utenti alla generazione dei codici. Il Soggetto accreditato nel sistema CUP funge da entità giuridica responsabile verso il sistema, garantendo che chi opera lo faccia per conto di un'istituzione ufficialmente riconosciuta."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Accredited subject of the CUP system"
  }, {
    "@language" : "it",
    "@value" : "Soggetto accreditato sistema cup"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/italia/onto/COV/Organization"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid179"
  }, {
    "@id" : "_:genid180"
  }, {
    "@id" : "_:genid181"
  }, {
    "@id" : "_:genid182"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Soggetto_attuatore_interventi_PNRR",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Public or private entity that implements the interventions envisaged by the PNRR (art. 1, paragraph 4, letter o), Legislative Decree no. 77/2021)."
  }, {
    "@language" : "it",
    "@value" : "Soggetto pubblico o privato che provvede alla realizzazione degli interventi previsti dal PNRR (art. 1, comma 4, lett. o), DL n. 77/2021)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Implementing body for PNRR interventions"
  }, {
    "@language" : "it",
    "@value" : "Soggetto attuatore interventi PNRR"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid183"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Soggetto_concentratore",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Public entity authorized to perform the CUP request functions upon delegation by the owner, based on specific agreements and providing evidence of this in the system, without prejudice to the owner's responsibilities regarding the obligation to request assignment of the CUP and the accuracy of the data entered into the system (CIPE Resolution no. 63 of 26 November 2020)."
  }, {
    "@language" : "it",
    "@value" : "Soggetto pubblico abilitato a svolgere le funzioni di richiesta del CUP su delega del soggetto titolare, sulla base di specifici accordi e dandone evidenza nel sistema, ferme restando le responsabilità del titolare per quanto concerne l’obbligo di richiesta di assegnazione del CUP e la correttezza dei dati inseriti nel sistema (Delibera CIPE n. 63 del 26 novembre 2020)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Concentrating subject"
  }, {
    "@language" : "it",
    "@value" : "Soggetto concentratore"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Soggetto_richiedente_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Soggetto che svolge le funzioni di richiesta del codice all'interno del sistema CUP; è immutabile nel tempo e solitamente coincide con il Soggetto responsabile del progetto (Soggetto titolare), in caso di delega il ruolo è assunto dal Soggetto concentratore."
  }, {
    "@language" : "en",
    "@value" : "The entity that performs the code request functions within the CUP system; it is unchangeable over time and usually coincides with the entity responsible for the project (Owner). In the event of delegation, the role is assumed by the Concentrating Entity."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Applicant subject CUP"
  }, {
    "@language" : "it",
    "@value" : "Soggetto richiedente cup"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid185"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Soggetto_titolare_progetto_investimento",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Entity responsible for implementing the interventions and, therefore, responsible for requesting the CUP:\r\na. For the construction of public works: the contracting authority, the concessionaire, or the Municipality;\r\nb. For the granting of incentives to production units: the public entity responsible for granting public resources or its delegate (including a private one); \r\nc. For the granting of aid to entities other than production units: the public entity holding the concession; \r\nd. For the purchase of goods and services or shareholdings/capital contributions: the public entity responsible for the spending decision; \r\ne. For the provision of services: the public entity implementing the project.\r\nThe project owner and the CUP requester are the same, except in the case of a CUP request by proxy granted to the \"concentrator\" entity.\r\n(CIPE Resolution no. 143 of 27 December 2002, referred to by CIPE Resolution no. 63 of 26 November 2020)."
  }, {
    "@language" : "it",
    "@value" : "Soggetto cui compete l'attuazione degli interventi e, quindi, responsabile della richiesta del CUP:\r\na. per la realizzazione dei lavori pubblici: la stazione appaltante, il concessionario o il Comune;\r\nb. per la concessione di incentivi a unità produttive: il soggetto pubblico cui spetta la competenza per la concessione delle risorse pubbliche o suo delegato (anche privato); \r\nc. per la concessione di aiuti a soggetti diversi dalle unità produttive: l’Ente pubblico titolare della concessione; \r\nd. per l’acquisto di beni e servizi o partecipazioni azionare/conferimenti capitale: l’ente pubblico titolare della decisione di spesa; \r\ne. per la realizzazione di servizi: l’ente pubblico che realizza il progetto.\r\nSoggetto titolare del progetto e soggetto richiedente il CUP coincidono salvo il caso di richiesta CUP su delega rilasciata al soggetto “concentratore”.\r\n(Delibera CIPE n. 143 del 27 dicembre 2002, richiamata dalla Delibera CIPE n. 63 del 26 novembre 2020)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Entity holding the investment project"
  }, {
    "@language" : "it",
    "@value" : "Soggetto titolare progetto investimento"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid188"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Sottoscrizione_iniziale_o_aumento_di_capitale",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A public investment project consisting of a public entity's decision to participate in a capital increase (or the formation of a new company, etc.) with the entity paying the costs associated with the operation (capital payment, etc.); the CUP is requested by the entity\" (Resolution no. 63 of November 26, 2020)."
  }, {
    "@language" : "it",
    "@value" : "Progetto d'investimento pubblico che consiste nella decisione di un ente pubblico di partecipare a un aumento di capitale sociale (o di costituzione di una nuova società ecc.) con il pagamento, da parte dell’ente, dei costi connessi all’operazione (versamento del capitale, ecc.); il CUP è richiesto dall’ente” (Delibera n. 63 del 26 novembre 2020)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Initial subscription or capital increase"
  }, {
    "@language" : "it",
    "@value" : "Sottoscrizione iniziale o aumento di capitale"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid194"
  }, {
    "@id" : "_:genid195"
  }, {
    "@id" : "_:genid196"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Sottosettore_di_intervento",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Identifica il sottolivello di Settore di intervento. Consente di raggruppare i progetti per ambiti omogenei. Ad esempio, nel caso di Settore 01 - infrastrutture di trasporto i Sottosettori di intervento saranno \"Aeroportuali\", \"Ferrovie\", \"Marittime, lacuali e fluviali\", \"Stradali\", \"Trasporto urbano\", \"Trasporti multimodali e altre modalità di trasporto\"."
  }, {
    "@language" : "en",
    "@value" : "Identifies the sub-level of the Sector of Intervention. It allows projects to be grouped into homogeneous areas. For example, in the case of Sector 01 - Transport Infrastructure, the Sub-Sectors of Intervention will be \"Airports\", \"Railways\", \"Maritime, Lake and River Transport\", \"Roads\", \"Urban Transport\", and \"Multimodal Transport and Other Modes of Transport\"."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Sottosettore di intervento"
  }, {
    "@language" : "en",
    "@value" : "Subsector of intervention"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_attivo_di_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "CUP status of a project in the planning/implementation phase (CIPE Resolution no. 63 of 26 November 2020)."
  }, {
    "@language" : "it",
    "@value" : "Stato del CUP di un progetto in fase di programmazione/attuazione (Delibera CIPE n. 63 del 26 novembre 2020)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Active state of cup"
  }, {
    "@language" : "it",
    "@value" : "Stato attivo di cup"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_cancellato_di_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "CUP status cancelled as it was generated due to a material error (CIPE Resolution no. 63 of 26 November 2020)."
  }, {
    "@language" : "it",
    "@value" : "Stato del CUP cancellato in quanto generato per errore materiale (Delibera CIPE n. 63 del 26 novembre 2020)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Cup status deleted"
  }, {
    "@language" : "it",
    "@value" : "Stato cancellato di cup"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_chiuso_di_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "CUP status closed when the project is physically completed, all payments and collections have been made and the procedural process is also completed (CIPE Resolution no. 63 of 26 November 2020)."
  }, {
    "@language" : "it",
    "@value" : "Stato del CUP chiuso quando il progetto è completato dal punto di vista fisico, tutti i pagamenti e gli incassi sono stati eseguiti ed è completato anche l’iter procedurale (Delibera CIPE n. 63 del 26 novembre 2020)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Closed state of cup"
  }, {
    "@language" : "it",
    "@value" : "Stato chiuso di cup"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_coerente_programma_spesa_di_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Stato del CUP allegato ad un atto amministrativo di finanziamento/autorizzazione di investimenti pubblici, la cui classificazione, riportata nell’anagrafica del sistema CUP, rispetta i vincoli disposti dalla normativa, che istituisce e regola il programma di spesa ai sensi del quale viene emanato l’atto stesso (Delibera CIPE n. 63 del 26 novembre 2020)."
  }, {
    "@language" : "en",
    "@value" : "Status of the CUP attached to an administrative act for the financing/authorization of public investments, whose classification, reported in the CUP system registry, complies with the constraints set by the legislation, which establishes and regulates the spending program pursuant to which the act itself is issued (CIPE Resolution no. 63 of 26 November 2020)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Consistent state of CUP spending program"
  }, {
    "@language" : "it",
    "@value" : "Stato coerente programma spesa di cup"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_completo_di_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Stato del CUP che possiede un corredo informativo integro e validato dal sistema. Questo prevede la compilazione di tutti i campi obbligatori, inclusi i dati finanziari e la localizzazione. Tutte queste informazioni sono pubbliche, ad eccezione di quelle riguardanti l’utente che ha richiesto il codice."
  }, {
    "@language" : "en",
    "@value" : "Status of the CUP having complete and system-validated information. This requires completing all mandatory fields, including financial data and location. All this information is public, except for that relating to the user who requested the code."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Complete state of cup"
  }, {
    "@language" : "it",
    "@value" : "Stato completo di cup"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_valido_di_Cup"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_corretto_di_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Stato del CUP definitivo allegato ad un atto di finanziamento/autorizzazione di investimenti pubblici, che possiede le caratteristiche necessarie per identificare un intervento/progetto, che l’amministrazione titolare manifesta di voler realizzare (Delibera CIPE n. 63 del 26 novembre 2020)."
  }, {
    "@language" : "en",
    "@value" : "Status of the final CUP attached to a public investment financing/authorization act, which has the necessary characteristics to identify an intervention/project, which the owner administration declares it wishes to implement (CIPE Resolution no. 63 of 26 November 2020)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Correct cup status"
  }, {
    "@language" : "it",
    "@value" : "Stato corretto di cup"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_di_atto_di_finanziamento",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "State that aggregates the conditions of correctness, consistency, and issuance of the administrative act that provides public funding or authorizes the implementation of specific public investment projects; it necessarily includes the CUP (Single Project Code) as an essential element, under penalty of nullity, to ensure the traceability and transparency of public investments."
  }, {
    "@language" : "it",
    "@value" : "Stato che aggrega le condizioni di correttezza, coerenza ed emanazione dell'atto amministrativo che dispone il finanziamento pubblico o autorizza l'esecuzione di specifici progetti di investimento pubblico; include necessariamente il CUP (Codice Unico di Progetto) come elemento essenziale, pena la nullità, per garantire tracciabilità e trasparenza degli investimenti pubblici."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Stato di atto di finanziamento"
  }, {
    "@language" : "en",
    "@value" : "Status of financing act"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/italia/onto/TI/TimeIndexedEvent"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid199"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_di_coerenza_di_atto_di_finanziamento",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "La condizione di un atto amministrativo di finanziamento/autorizzazione di investimenti pubblici, la cui classificazione, riportata nell’anagrafica del sistema CUP, rispetta i vincoli disposti dalla normativa che istituisce e regola il programma di spesa ai sensi del quale viene emanato l’atto stesso."
  }, {
    "@language" : "en",
    "@value" : "The condition of an administrative act financing/authorizing public investments, whose classification, reported in the CUP system registry, complies with the constraints set forth in the legislation establishing and regulating the spending program under which the act itself is issued."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "State of coherence of financing act"
  }, {
    "@language" : "it",
    "@value" : "Stato di coerenza di atto di finanziamento"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_di_correttezza_di_atto_di_finanziamento",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "La condizione di un atto amministrativo di finanziamento/autorizzazione di investimenti pubblici che possiede le caratteristiche necessarie per identificare un intervento/progetto, che l’amministrazione titolare manifesta di voler realizzare. "
  }, {
    "@language" : "en",
    "@value" : "The condition of an administrative act of financing/authorization of public investments that possesses the characteristics necessary to identify an intervention/project, which the owner administration declares it wishes to implement."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Stato di correttezza di atto di finanziamento"
  }, {
    "@language" : "en",
    "@value" : "Status of correctness of financing act"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_di_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Administrative and technical status of the CUP within the Project Registry: active; cancelled; closed; provisional; consistent with the spending plan; complete; correct; valid; revoked."
  }, {
    "@language" : "it",
    "@value" : "Condizione amministrativa e tecnica del CUP all'interno dell'Anagrafe Progetti: attivo; cancellato; chiuso; provvisorio; coerente con il programma di spesa; completo; corretto; valido; revocato."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Cup status"
  }, {
    "@language" : "it",
    "@value" : "Stato di cup"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/italia/onto/TI/TimeIndexedEvent"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid201"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_di_emanazione_di_atto_di_finanziamento",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "La condizione di un atto amministrativo di finanziamento/autorizzazione di investimenti pubblici a cui è associato uno Stato attivo di CUP, relativo ad un progetto in fase di programmazione/attuazione."
  }, {
    "@language" : "en",
    "@value" : "The condition of an administrative act of financing/authorization of public investments to which an active CUP status is associated, relating to a project in the planning/implementation phase."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "State of issue of financing act"
  }, {
    "@language" : "it",
    "@value" : "Stato di emanazione di atto di finanziamento"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_provvisorio_di_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Optional CUP status, with no administrative relevance, which some administrations use to record the project from the very beginning of the project idea, when the investment cost and financing are not yet imaginable. Technically, the code string contains one fewer character than the final CUP, and the first three are characterized by the letters PROV, for example: PROV0000019464 (CIPE Resolution no. 63 of November 26, 2020)."
  }, {
    "@language" : "it",
    "@value" : "Stato del CUP facoltativo, e privo di rilevanza amministrativa, che alcune amministrazioni utilizzano per censire il progetto sin dalla nascita dell’idea progettuale, quando ancora non sono immaginabili i valori riguardanti il costo e il finanziamento dell’investimento. Dal punto di vista tecnico, la stringa di codice contiene un carattere in meno del CUP definitivo e i primi tre sono caratterizzati dalle lettere PROV esempio: PROV0000019464 (Delibera CIPE n. 63 del 26 novembre 2020)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Provisional status of cup"
  }, {
    "@language" : "it",
    "@value" : "Stato provvisorio di cup"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_revocato_di_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "CUP status revoked because the entity responsible for the project decides not to implement it before its closure (CIPE Resolution no. 63 of 26 November 2020)."
  }, {
    "@language" : "it",
    "@value" : "Stato del CUP revocato perché il soggetto titolare dell’intervento decide di non realizzarlo prima della sua chiusura (Delibera CIPE n. 63 del 26 novembre 2020)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "CUP status revoked"
  }, {
    "@language" : "it",
    "@value" : "Stato revocato di cup"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_valido_di_Cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Stato del CUP definitivo generato ed esistente all’interno del sistema informativo CUP (Delibera CIPE n. 63 del 26 novembre 2020)."
  }, {
    "@language" : "en",
    "@value" : "Status of the final CUP generated and existing within the CUP information system (CIPE Resolution no. 63 of 26 November 2020)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Stato valido di cup"
  }, {
    "@language" : "en",
    "@value" : "Valid cup status"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Storia_di_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A chronological and immutable log of all changes, additions, and status changes affecting a given CUP from its generation until its closure or revocation. It tracks each event, the operator that generated it, and the time it occurred."
  }, {
    "@language" : "it",
    "@value" : "Registro cronologico e immutabile di tutte le variazioni, integrazioni e passaggi di stato che hanno interessato un determinato CUP dalla sua generazione fino alla chiusura o revoca. Tiene traccia di ogni evento, dell'operatore che lo genera e del momento in cui viene generato."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "History of cup"
  }, {
    "@language" : "it",
    "@value" : "Storia di cup"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/italia/onto/l0/Sequence"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid203"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Strumento_di_programmazione",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An implementation tool for managing and allocating financial resources to achieve specific objectives based on a specific annual or three-year plan."
  }, {
    "@language" : "it",
    "@value" : "Strumento di attuazione per la gestione e l'allocazione delle risorse finanziarie con la finalità di realizzare obiettivi specifici sulla base di un determinato piano annuale o triennale."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Programming tool"
  }, {
    "@language" : "it",
    "@value" : "Strumento di programmazione"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid205"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Strumento_di_programmazione_libero",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Si tratta della sottocategoria residuale di strumento di programmazione e rappresenta il dettaglio descrittivo o il nome specifico dello strumento qualora non sia riconducibile a una categoria standard o necessiti di ulteriore specificazione. Consente all'utente di inserire testualmente il nome del piano, dell'accordo o del programma specifico e fornisce flessibilità al corredo informativo, permettendo di tracciare strumenti di programmazione locali o specifici che non rientrano nelle tipologie generali predefinite."
  }, {
    "@language" : "en",
    "@value" : "This is the residual subcategory of programming tools and represents the descriptive detail or specific name of the tool if it doesn't fit into a standard category or requires further specification. It allows the user to enter the name of the specific plan, agreement, or program and provides flexibility in the information set, allowing for the tracking of local or specific programming tools that don't fit into the predefined general typologies."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Free programming tool"
  }, {
    "@language" : "it",
    "@value" : "Strumento di programmazione libero"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_strumento_di_programmazione"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Subinvestimento_PNRR",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Articolazione di dettaglio della Tematica PNRR che identifica la specifica linea di finanziamento a cui il progetto è collegato; la sua selezione, obbligatoria per i progetti PNRR, definisce il perimetro operativo dell'intervento e vincola la scelta dei Target PNRR di progetto ai soli obiettivi associati a quella specifica misura."
  }, {
    "@language" : "en",
    "@value" : "Detailed breakdown of the PNRR Theme that identifies the specific funding line to which the project is linked; its selection, mandatory for PNRR projects, defines the operational scope of the intervention and limits the choice of PNRR project targets to the objectives associated with that specific measure."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PNRR sub-investment"
  }, {
    "@language" : "it",
    "@value" : "Sub-investimento PNRR"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid208"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Target_PNRR",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "It represents the quantitative or qualitative objective (milestone/target) defined at the national level for a specific PNRR sub-investment; it serves as a benchmark for measuring the Plan's progress and constitutes the hub to which the individual PNRR project targets are linked for reporting results."
  }, {
    "@language" : "it",
    "@value" : "Rappresenta l'obiettivo quantitativo o qualitativo (milestone/target) definito a livello nazionale per un determinato Sub-investimento PNRR; funge da parametro di riferimento per misurare l'avanzamento del Piano e costituisce il nodo a cui si agganciano i singoli Target PNRR di progetto per la rendicontazione dei risultati."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PNRR Target"
  }, {
    "@language" : "it",
    "@value" : "Target PNRR"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid210"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Target_PNRR_di_progetto",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Costituisce la quota parte dell'obiettivo nazionale (Target PNRR) che il singolo Progetto di Investimento Pubblico si impegna a realizzare; è il valore specifico inserito nel corredo informativo del CUP che permette di verificare il contributo puntuale del progetto al raggiungimento dei traguardi previsti dal monitoraggio europeo."
  }, {
    "@language" : "en",
    "@value" : "This represents the share of the national objective (PNRR Target) that each Public Investment Project commits to achieving; it is the specific value included in the CUP information package that allows verification of the project's specific contribution to achieving the goals set by European monitoring."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PNRR project targets"
  }, {
    "@language" : "it",
    "@value" : "Target PNRR di progetto"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid212"
  }, {
    "@id" : "_:genid213"
  }, {
    "@id" : "_:genid215"
  }, {
    "@id" : "_:genid216"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tematica_PNRR",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Campo del corredo informativo del Progetto di investimento pubblico che identifica l'area strategica dell'intervento, obbligatorio per i progetti che beneficiano di fondi PNRR; la sua compilazione comporta l'attivazione automatica dei campi relativi al Sub-investimento e ai Target di progetto per il monitoraggio europeo."
  }, {
    "@language" : "en",
    "@value" : "This field in the Public Investment Project information package identifies the strategic area of ​​intervention, mandatory for projects receiving PNRR funding. Completing this field automatically activates the fields for Sub-investment and Project Targets for European monitoring."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "PNRR Theme"
  }, {
    "@language" : "it",
    "@value" : "Tematica PNRR"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_area_soggetto_accreditato",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Campo che definisce l’ambito di competenza funzionale o settoriale prevalente del Soggetto accreditato al Sistema CUP (es. Sanità, Istruzione, Trasporti). Permette al sistema di associare il Soggetto ai rispettivi settori di intervento e agevola i flussi di monitoraggio verso le amministrazioni centrali competenti per materia."
  }, {
    "@language" : "en",
    "@value" : "This field defines the primary functional or sectoral area of ​​expertise of the entity accredited to the CUP System (e.g., Healthcare, Education, Transportation). It allows the system to associate the entity with its respective sectors of intervention and facilitates monitoring flows to the central administrations responsible for the relevant subject matter."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Tipo area soggetto accreditato"
  }, {
    "@language" : "en",
    "@value" : "Type of accredited subject area"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_categoria_soggetto_accreditato",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Campo del corredo informativo che definisce il macro-settore di appartenenza del Soggetto accreditato al Sistema CUP (es. Amministrazioni Centrali, Enti Locali, Società Pubbliche). Rappresenta il primo livello di classificazione del Soggetto e determina l’ambito istituzionale in cui l’ente opera all'interno dell'Anagrafe Soggetti."
  }, {
    "@language" : "en",
    "@value" : "This information field defines the macro-sector to which the entity accredited to the CUP System belongs (e.g., Central Administrations, Local Authorities, Public Companies). It represents the first level of entity classification and determines the institutional context in which the entity operates within the Register of Individuals."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Accredited subject category type"
  }, {
    "@language" : "it",
    "@value" : "Tipo categoria soggetto accreditato"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_di_finalità_partecipazione_conferimento",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Campo del corredo informativo, attivato esclusivamente per i progetti con Natura \"Sottoscrizione iniziale o aumento di capitale sociale (compresi spin off), fondi di rischio o di garanzia\", che specifica lo scopo istituzionale o economico dell'operazione finanziaria. Serve a distinguere se il conferimento di capitale o la creazione di un fondo sia finalizzato al sostegno di attività produttive, alla ricerca e sviluppo (spin-off) o alla gestione di rischi finanziari."
  }, {
    "@language" : "en",
    "@value" : "This field in the information package, activated exclusively for projects with the \"Initial subscription or increase in share capital (including spin-offs), venture or guarantee funds\" nature, specifies the institutional or economic purpose of the financial transaction. It is used to distinguish whether the capital injection or the creation of a fund is intended to support production activities, research and development (spin-offs), or financial risk management."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Tipo di finalità partecipazione conferimento"
  }, {
    "@language" : "en",
    "@value" : "Type of purpose participation contribution"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_motivazione_assenza_CUP_di_progettazione",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Insieme delle causali selezionabili nel sistema per giustificare la mancata associazione di un cup di progettazione con Natura 2 ad un cup di Natura 3"
  }, {
    "@language" : "en",
    "@value" : "Set of reasons that can be selected in the system to justify the failure to associate a Nature 2 design CUP with a Nature 3 CUP"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Tipo motivazione assenza CUP di progettazione"
  }, {
    "@language" : "en",
    "@value" : "Type of reason for absence of CUP planning"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_natura_giuridica_soggetto_accreditato",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Attribute that identifies the legal status of the entity accredited to the CUP system (e.g., Public Economic Entity, Constitutional Body, Joint Stock Company). This information is essential for defining the legal provisions (public or private) to which the entity is subject and, consequently, its powers in the context of spending procedures."
  }, {
    "@language" : "it",
    "@value" : "Attributo che identifica la veste legale del Soggetto accreditato al Sistema CUP (es. Ente Pubblico Economico, Organo Costituzionale, Società per Azioni). Questo dato è fondamentale per definire le norme di diritto (pubblico o privato) a cui l'ente è soggetto e, conseguentemente, le sue facoltà nell'ambito dei procedimenti di spesa."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Tipo natura giuridica soggetto accreditato"
  }, {
    "@language" : "en",
    "@value" : "Type of legal nature of accredited entity"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_sottocategoria_soggetto_accreditato",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A detailed element that further specifies the Category to which the CUP System-accredited entity belongs for more precise profiling (e.g., within the \"Local Authorities\" category, it distinguishes between Municipalities, Provinces, or Metropolitan Cities). It serves to group entities by similarity of administrative functions and territorial competences."
  }, {
    "@language" : "it",
    "@value" : "Elemento di dettaglio che specifica ulteriormente la Categoria di appartenenza del Soggetto accreditato al Sistema CUP per una profilazione più precisa (es. all'interno della categoria \"Enti Locali\", distingue tra Comuni, Province o Città Metropolitane). Serve a raggruppare i soggetti per affinità di funzioni amministrative e competenze territoriali."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Accredited entity subcategory type"
  }, {
    "@language" : "it",
    "@value" : "Tipo sottocategoria soggetto accreditato"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_strumento_di_programmazione",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Si tratta di una sottocategoria di strumento di programmazione che si basa su un elenco predefinito (dominio di valori) fornito dal sistema CUP. Identifica la natura giuridico-amministrativa dell'atto di programmazione e permette l'aggregazione statistica dei dati e il monitoraggio a livello nazionale, facilitando il confronto tra programmi simili."
  }, {
    "@language" : "en",
    "@value" : "This is a subcategory of programming tools based on a predefined list (value domain) provided by the CUP system. It identifies the legal-administrative nature of the programming act and allows for statistical data aggregation and monitoring at the national level, facilitating comparisons between similar programs."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Programming tool type"
  }, {
    "@language" : "it",
    "@value" : "Tipo strumento di programmazione"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipologia_copertura_finanziaria",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Campo obbligatorio del corredo informativo che identifica le fonti economiche destinate al Progetto d'investimento pubblico, permettendo l'associazione di più valori (pubblici, privati o propri) tramite un sistema di inserimento multiplo. La sua compilazione è governata da logiche di esclusività dipendenti dal campo \"Partenariato Pubblico-Privato\": se il partenariato è assente, sono ammesse solo fonti pubbliche; se è totale, solo fonti private; se è parziale, il sistema consente l'integrazione di entrambe le tipologie di risorse. Funge da filtro di validazione per assicurare che la struttura finanziaria dichiarata sia coerente con la forma contrattuale dell'investimento."
  }, {
    "@language" : "en",
    "@value" : "This mandatory field in the information package identifies the financial sources allocated to the public investment project, allowing the association of multiple values ​​(public, private, or own) through a multiple entry system. Its compilation is governed by exclusivity criteria based on the \"Public-Private Partnership\" field: if there is no partnership, only public sources are permitted; if there is a full partnership, only private sources are permitted; if there is a partial partnership, the system allows the integration of both types of resources. It serves as a validation filter to ensure that the declared financial structure is consistent with the contractual form of the investment."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Tipologia copertura finanziaria"
  }, {
    "@language" : "en",
    "@value" : "Type of financial coverage"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipologia_di_intervento",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "it",
    "@value" : "Identifica con maggior livello di dettaglio la Natura di intervento e serve a specificare il metodo di attuazione. Ad esempio, nel caso di Natura 01 - Acquisto di beni, le Tipologie di intervento saranno \"Nuova fornitura\", \"Manutenzione straordinaria\" o \"Altro\")."
  }, {
    "@language" : "en",
    "@value" : "It identifies the nature of the intervention in greater detail and serves to specify the implementation method. For example, in the case of Nature 01 - Purchase of goods, the types of intervention will be \"New supply\", \"Extraordinary maintenance\", or \"Other\")."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "Tipologia di intervento"
  }, {
    "@language" : "en",
    "@value" : "Type of intervention"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Unità_organizzativa",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Service, Office, Management, Department of the Entity responsible for the project to which the reference user who interacts with the CUP System belongs."
  }, {
    "@language" : "it",
    "@value" : "Servizio, Ufficio, Direzione, Dipartimento del Soggetto responsabile del progetto cui appartiene l’utente di riferimento che interagisce con il Sistema CUP."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Organizational unit"
  }, {
    "@language" : "it",
    "@value" : "Unità organizzativa"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid217"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Utente_richiedente_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A natural person, unchangeable over time, who has registered in the system as a generating user and has requested a CUP. This person may be a Responsible Entity (Controller Entity) or a Concentrator Entity."
  }, {
    "@language" : "it",
    "@value" : "Persona fisica, immutabile nel tempo, che si è registrata al sistema come utente generatore e che ha richiesto il CUP. Può far capo ad un Soggetto responsabile (Soggetto Titolare) o ad un Soggetto concentratore."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "User requesting cup"
  }, {
    "@language" : "it",
    "@value" : "Utente richiedente cup"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Utente_sistema_cup"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Utente_riferimento_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A natural person, variable over time, who has registered in the system as a generator user and who interacts with the CUP system for information or to maintain the information set of active projects. This person reports to the Responsible Entity (Controller Entity)."
  }, {
    "@language" : "it",
    "@value" : "Persona fisica, variabile nel tempo, che si è registrata al sistema come utente generatore e che interagisce con il sistema CUP per informazioni o per la manutenzione del corredo informativo di progetti attivi. Fa capo al Soggetto responsabile (Soggetto Titolare)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "User reference cup"
  }, {
    "@language" : "it",
    "@value" : "Utente riferimento cup"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Utente_sistema_cup"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Utente_sistema_cup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A natural person who, following an accreditation procedure, interacts with the CUP system. They can register as a \"generator\" if, in addition to querying the database, they are interested in requesting codes and performing related operations, or as a \"reader\" if they only need to view the contents of the system's database."
  }, {
    "@language" : "it",
    "@value" : "Persona fisica che, in seguito ad una procedura di accreditamento, interagisce con il sistema CUP. Può accreditarsi come “generatore“, se, oltre ad interrogare la banca dati, è interessato a richiedere codici ed effettuare le relative operazioni collegate, o come “lettore“, se ha solo l’esigenza di visualizzare il contenuto della banca dati del sistema."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Cup system user"
  }, {
    "@language" : "it",
    "@value" : "Utente sistema cup"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "_:genid220"
  }, {
    "@id" : "_:genid227"
  } ],
  "http://www.w3.org/2002/07/owl#equivalentClass" : [ {
    "@id" : "_:genid219"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_di_beni",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "acquisto di beni"
  }, {
    "@language" : "en",
    "@value" : "purchase of goods"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_o_realizzazione_corso_di_formazione",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "acquisto o realizzazione corso di formazione"
  }, {
    "@language" : "en",
    "@value" : "purchase or completion of a training course"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_o_realizzazione_di_servizi",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "acquisto o realizzazione di servizi"
  }, {
    "@language" : "en",
    "@value" : "purchase or provision of services"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_o_realizzazione_progetto_di_ricerca",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "acquisto o realizzazione progetto di ricerca"
  }, {
    "@language" : "en",
    "@value" : "purchase or implementation of research project"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_o_realizzazione_studio_o_progettazione",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "acquisto o realizzazione studio o progettazione"
  }, {
    "@language" : "en",
    "@value" : "purchase or implementation of study or design"
  } ]
}, {
  "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ambito_di_delega",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty", "http://www.w3.org/2002/07/owl#FunctionalProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Delega_richiesta_cup"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "it",
    "@value" : "ambito di delega"
  }, {
    "@language" : "en",
    "@value" : "scope of delegation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#string"
