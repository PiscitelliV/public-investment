    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_di_beni -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_di_beni">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_natura_intervento"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:oneOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_di_beni"/>
                        </owl:oneOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/bene_acquistato"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/opera_infrastruttura_progetto"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A public investment project by a public entity for the purchase of &quot;durable&quot; goods (hospital equipment, offices, or furniture for administrative offices), with the entity itself paying the costs requested by the seller; the CUP is requested by the entity owning the project. (CIPE Resolution No. 63/2020).</rdfs:comment>
        <rdfs:comment xml:lang="it">Progetto di investimento pubblico di un ente pubblico per l’acquisto di beni «durevoli» (macchinari di un ospedale, sedi o arredi per uffici amministrativi) con il pagamento, da parte dell’ente medesimo, dei costi richiesti dal venditore; il CUP è richiesto dall’ente titolare del progetto. (Delibera CIPE n. 63/2020).</rdfs:comment>
        <rdfs:label xml:lang="it">Acquisto di beni</rdfs:label>
        <rdfs:label xml:lang="en">Purchase of goods</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_o_realizzazione_altro_servizio -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_o_realizzazione_altro_servizio">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_tipologia_intervento"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:complementOf>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <owl:Class>
                                        <owl:oneOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_o_realizzazione_corso_di_formazione"/>
                                        </owl:oneOf>
                                    </owl:Class>
                                    <owl:Class>
                                        <owl:oneOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_o_realizzazione_progetto_di_ricerca"/>
                                        </owl:oneOf>
                                    </owl:Class>
                                    <owl:Class>
                                        <owl:oneOf rdf:parseType="Collection">
                                            <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_o_realizzazione_studio_o_progettazione"/>
                                        </owl:oneOf>
                                    </owl:Class>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:complementOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/infrastruttura_di_progetto"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/servizio_acquistato_realizzato"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Sottoclasse di Acquisto o realizzazione di servizi, residuale rispetto ai corsi di formazione e ai progetti di ricerca.</rdfs:comment>
        <rdfs:comment xml:lang="en">Subclass of Purchase or realization of services, residual with respect to training courses and research projects.</rdfs:comment>
        <rdfs:label xml:lang="it">Acquisto o realizzazione altro servizio</rdfs:label>
        <rdfs:label xml:lang="en">Purchase or provision of another service</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_o_realizzazione_corso_di_formazione -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_o_realizzazione_corso_di_formazione">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_natura_intervento"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:oneOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_o_realizzazione_di_servizi"/>
                                </owl:oneOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_tipologia_intervento"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:oneOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_o_realizzazione_corso_di_formazione"/>
                                </owl:oneOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_ente_erogatore_corso_di_formazione"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/denominazione_corso_di_formazione"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/modalità_corso_di_formazione"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/obiettivo_corso_di_formazione"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Sottoclasse di Acquisto o realizzazione di servizi, relativa ai corsi di formazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">Subclass of Purchase or provision of services, relating to training courses.</rdfs:comment>
        <rdfs:label xml:lang="it">Acquisto o realizzazione corso di formazione</rdfs:label>
        <rdfs:label xml:lang="en">Purchase or completion of a training course</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_o_realizzazione_di_servizi -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_o_realizzazione_di_servizi">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_o_realizzazione_altro_servizio"/>
                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_o_realizzazione_corso_di_formazione"/>
                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_o_realizzazione_progetto_di_ricerca"/>
                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_o_realizzazione_studio_o_progettazione"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="it">Progetto di investimento pubblico di un ente pubblico (richiedente il CUP) per:  
-l’acquisto di servizi di sviluppo (un progetto di ricerca, l’adeguamento di un software, un corso di formazione) con il pagamento, da parte dell’ente, dei costi richiesti dal venditore; 
-la realizzazione di servizi di sviluppo (un progetto di ricerca, l’adeguamento di un software, un corso di formazione) con il pagamento, da parte dell’ente, dei costi connessi alle attività realizzative; rientrano in questa casistica i servizi di progettazione di opere pubbliche, se tali attività sono definite in relazione a un quadro economico di spesa specifico, distinto dalla realizzazione dell’opera. (Delibera CIPE n. 63/2020).</rdfs:comment>
        <rdfs:comment xml:lang="en">Public investment project by a public entity (applicant for the CUP) for:
- the purchase of development services (a research project, software upgrades, a training course) with the entity paying the costs requested by the vendor;
- the implementation of development services (a research project, software upgrades, a training course) with the entity paying the costs associated with the implementation activities; this category includes public works design services, if such activities are defined in relation to a specific economic expenditure framework, distinct from the construction of the work. (CIPE Resolution No. 63/2020).</rdfs:comment>
        <rdfs:label xml:lang="it">Acquisto o realizzazione di servizi</rdfs:label>
        <rdfs:label xml:lang="en">Purchase or provision of services</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_o_realizzazione_progetto_di_ricerca -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_o_realizzazione_progetto_di_ricerca">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_natura_intervento"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:oneOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_o_realizzazione_di_servizi"/>
                                </owl:oneOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_tipologia_intervento"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:oneOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_o_realizzazione_progetto_di_ricerca"/>
                                </owl:oneOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_ente_realizzatore_progetto_di_ricerca"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/denominazione_progetto_di_ricerca"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">Sottoclasse di Acquisto o realizzazione di servizi, relativa ai progetti di ricerca.</rdfs:comment>
        <rdfs:comment xml:lang="en">Subclass of Purchase or provision of services, relating to research projects.</rdfs:comment>
        <rdfs:label xml:lang="it">Acquisto o realizzazione progetto di ricerca</rdfs:label>
        <rdfs:label xml:lang="en">Purchase or implementation of research project</rdfs:label>
        <rdfs:label>Acquisto o realizzazione progetto di ricerca</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_o_realizzazione_studio_o_progettazione -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_o_realizzazione_studio_o_progettazione">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_natura_intervento"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:oneOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_o_realizzazione_di_servizi"/>
                                </owl:oneOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_tipologia_intervento"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:oneOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_o_realizzazione_studio_o_progettazione"/>
                                </owl:oneOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="it">Sottoclasse di Acquisto o realizzazione di servizi che identifica le attività preliminari di studio o progettazione tecnica di un&apos;opera, esclusivamente nell&apos;ambito della Natura 3 &quot;Realizzazione di lavori pubblici (opera ed impiantistica)&quot; laddove sia collegata alla Natura 2 per la tipologia &quot;Studi e progettazione&quot;. I servizi di progettazione possono essere acquisiti da fornitori esterni tramite procedure di gara, oppure possono essere svolti internamente all&apos;amministrazione da parte della struttura organizzativa competente.</rdfs:comment>
        <rdfs:comment xml:lang="en">Subclass of Purchase or provision of services identifies the preliminary study or technical design activities for a project, exclusively within the scope of Nature 3 &quot;Public works (construction and systems)&quot; where it is linked to Nature 2 for the &quot;Studies and design&quot; typology. Design services may be acquired from external suppliers through tender procedures, or they may be performed internally by the administration by the competent organizational structure.</rdfs:comment>
        <rdfs:label xml:lang="it">Acquisto o realizzazione studio o progettazione</rdfs:label>
        <rdfs:label xml:lang="en">Purchase or implementation of study or design</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Area_di_intervento -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Area_di_intervento">
        <rdfs:comment xml:lang="it">Lista a scelta singola contenente le aree d’intervento compatibilmente alla Natura selezionata, relativa ai metadati di OpenCUP. Individua le categorie omogenee con cui è possibile descrivere &quot;l&apos;oggetto progettuale&quot; (n. 6 aree – Classificazione con relativi codici):
01 – Immobili
02 – Trasporti
03 – Ambiente ed energia
04 – Aree produttive
05 – Ricerca, ITC, formazione ed altro
06 – Servizi per la P.A. e per la collettività.</rdfs:comment>
        <rdfs:comment xml:lang="en">Single-choice list containing the areas of intervention compatible with the selected Nature, relative to the OpenCUP metadata. Identify the homogeneous categories with which to describe the &quot;project object&quot; (6 areas – Classification with related codes):
01 – Real Estate
02 – Transportation
03 – Environment and Energy
04 – Production Areas
05 – Research, ICT, Training and Other
06 – Services for the Public Administration and the Community.</rdfs:comment>
        <rdfs:label xml:lang="it">Area di intervento</rdfs:label>
        <rdfs:label xml:lang="en">Area of ​​intervention</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/data_atto"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">Any expression of will capable of producing legal effects.</rdfs:comment>
        <rdfs:comment xml:lang="it">Qualsiasi manifestazione di volontà capace di produrre effetti giuridici.</rdfs:comment>
        <rdfs:label xml:lang="en">Act</rdfs:label>
        <rdfs:label xml:lang="it">Atto</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_amministrativo_progetto_cumulativo -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_amministrativo_progetto_cumulativo">
        <rdfs:comment xml:lang="en">Administrative provision adopted by the public administration responsible for the public investment project concerning a complex of interventions consisting of the granting of contributions to entities that are not production units, by which multiple projects or beneficiaries are jointly regulated and approved.</rdfs:comment>
        <rdfs:comment xml:lang="it">Provvedimento amministrativo adottato dalla pubblica amministrazione responsabile del progetto di investimento pubblico avente ad oggetto un complesso di interventi consistenti nella concessione di contributi a soggetti che non sono unità produttive, con il quale vengono disciplinati e approvati congiuntamente più progetti o beneficiari.</rdfs:comment>
        <rdfs:label xml:lang="en">Administrative act cumulative project</rdfs:label>
        <rdfs:label xml:lang="it">Atto amministrativo progetto cumulativo</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_autorizzazione_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_autorizzazione_cup">
        <rdfs:comment xml:lang="en">Administrative provision formalizing the decision to implement a public investment project, constituting the legal basis for requesting the code. It identifies the decision-maker, the allocated resources, and the scope of the project. The details (date and protocol) of the project must be entered into the system to ensure document and accounting traceability.</rdfs:comment>
        <rdfs:comment xml:lang="it">Provvedimento amministrativo che formalizza la decisione di realizzare un Progetto d&apos;investimento pubblico, costituendo il presupposto giuridico per la richiesta del codice. Esso identifica il decisore, le risorse stanziate e l&apos;oggetto dell&apos;intervento, i cui estremi (data e protocollo) devono essere inseriti nel sistema per garantirne la tracciabilità documentale e contabile.</rdfs:comment>
        <rdfs:label xml:lang="it">Atto autorizzazione cup</rdfs:label>
        <rdfs:label xml:lang="en">CUP Authorization Act</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_cancellazione_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_cancellazione_cup">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_atto_cancellazione_cup"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">Corrective action performed exclusively to eliminate a code generated due to a material error. Unlike revocation, this action invalidates the CUP from the outset, provided there are no other related projects or technical constraints preventing its logical removal from the system.</rdfs:comment>
        <rdfs:comment xml:lang="it">Operazione correttiva effettuata esclusivamente per eliminare un codice generato per errore materiale. A differenza della revoca, essa annulla la validità del CUP fin dall&apos;origine, a patto che non vi siano altri progetti collegati o vincoli tecnici che ne impediscano la rimozione logica dal sistema.</rdfs:comment>
        <rdfs:label xml:lang="it">Atto cancellazione cup</rdfs:label>
        <rdfs:label xml:lang="en">CUP Cancellation Act</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_chiusura_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_chiusura_cup">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_atto_chiusura_cup"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="it">Operazione che identifica lo stato finale del ciclo di vita di un CUP e formalizza la conclusione definitiva di un Progetto d&apos;investimento pubblico nel sistema di monitoraggio. Può essere adottato solo quando l&apos;intervento è ultimato fisicamente, tutti i flussi finanziari (incassi e pagamenti) sono stati perfezionati e l&apos;iter amministrativo è concluso, portando il codice allo stato di &quot;chiuso&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">This operation identifies the final stage of a CUP&apos;s life cycle and formalizes the definitive conclusion of a public investment project in the monitoring system. It can only be adopted once the project has been physically completed, all financial flows (receipts and payments) have been finalized, and the administrative process has been concluded, resulting in the code being &quot;closed.&quot;</rdfs:comment>
        <rdfs:label xml:lang="it">Atto chiusura cup</rdfs:label>
        <rdfs:label xml:lang="en">Cup closing act</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_delega_richiesta_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_delega_richiesta_cup">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_delegante_richiesta_cup"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_delegato_richiesta_cup"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_utente_conferente_delega"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">Act of the public administration holding the investment and, therefore, responsible for the CUP request by which, on the basis of specific agreements, the delegation of the CUP request is formalized to a suitable authorized public body (so-called &quot;concentrator&quot;) who will provide evidence of it in the system, without prejudice to the former&apos;s responsibilities regarding the obligation to request the CUP assignment and the accuracy of the data entered into the system.</rdfs:comment>
        <rdfs:comment xml:lang="it">Atto della pubblica amministrazione titolare dell&apos;investimento e, quindi, responsabile di richiesta cup con il quale, sulla base di specifici accordi, si formalizza la delega della richiesta del CUP ad idoneo soggetto pubblico abilitato (cosiddetto «concentratore») che ne darà evidenza nel sistema, ferme restando le responsabilità del primo per quanto concerne l’obbligo di richiesta di assegnazione del CUP e la correttezza dei dati inseriti nel sistema».</rdfs:comment>
        <rdfs:label xml:lang="it">Atto delega richiesta cup</rdfs:label>
        <rdfs:label xml:lang="en">Delegation deed for CUP request</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_finanziamento_investimento_pubblico -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_finanziamento_investimento_pubblico">
        <rdfs:comment xml:lang="en">An administrative act, including a regulatory act, adopted by a public administration (Article 1, paragraph 2, Legislative Decree no. 165/2001), which provides for public funding or authorizes the implementation of public investment projects. The same administrative act includes the CUP (which allows for the tracking and monitoring of the project itself) of the authorized projects in the spending program, indicating the funding granted under those measures, the effective date of that funding, and the total value of the individual investments. The act, which may take the form, for example, of a resolution, a management order, a decree, or a measure approving one or more rankings, is null and void in the absence of the corresponding CUP, which constitutes an essential element of the act itself (Article 11 bis, paragraph 2 bis, Law no. 3/2003; CIPE Resolution no. 54 of July 22, 2010).</rdfs:comment>
        <rdfs:comment xml:lang="it">Atto amministrativo anche di natura regolamentare, adottato da una pubblica amministrazione (art. 1, comma 2, d. lgs. n. 165/2001), che dispone il finanziamento pubblico o autorizza l&apos;esecuzione di progetti di investimento pubblico. Nello stesso atto amministrativo, è associato il CUP (che permette di tracciare e monitorare il progetto stesso) dei progetti autorizzati al programma di spesa con l&apos;indicazione dei finanziamenti concessi a valere su dette misure, della data di efficacia di detti finanziamenti e del valore complessivo dei singoli investimenti. L&apos;atto, che si può esplicare, ad esempio, in una delibera, un provvedimento dirigenziale, un decreto, un provvedimento di approvazione di una o più graduatorie, è nullo in assenza del corrispondente CUP che costituisce elemento essenziale dell&apos;atto stesso (art. 11 bis, comma 2 bis, L. n. 3/2003; Delibera CIPE n. 54 del 22 luglio 2010). </rdfs:comment>
        <rdfs:label xml:lang="it">Atto finanziamento investimento pubblico</rdfs:label>
        <rdfs:label xml:lang="en">Public Investment Financing Act</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_generazione_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_generazione_cup">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_atto_generazione_cup"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="it">Procedura telematica di richiesta e rilascio del CUP, obbligatoria per ogni investimento pubblico sin dalla sua approvazione. Esso richiede l&apos;inserimento di un corredo informativo dettagliato (costi, obiettivi, localizzazione) che garantisce la tracciabilità e la validità giuridica del progetto stesso.</rdfs:comment>
        <rdfs:comment xml:lang="en">The online procedure for requesting and issuing the CUP is mandatory for all public investments from the moment of approval. It requires the inclusion of detailed information (costs, objectives, location) that ensures the project&apos;s traceability and legal validity.</rdfs:comment>
        <rdfs:label xml:lang="it">Atto generazione cup</rdfs:label>
        <rdfs:label xml:lang="en">Generation Cup Act</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_modifica_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_modifica_cup">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_atto_modifica_cup"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">An administrative and technical procedure that allows updating a project&apos;s information to ensure consistency with the evolution of the administrative decision. The operations are divided into:
Simple operations that can be performed independently by the authorized user via the system&apos;s &quot;Edit&quot; functions:
- Information modification: includes updating the project&apos;s descriptive and personal data (e.g., title or description) and/or financial data (e.g., revision of the overall cost and related financing plan) that do not alter the project&apos;s fundamental identity.
Complex and assisted operations that require sending a specific request to the Support Structure via the &quot;Send Change Request&quot; function:
- Replacement of the CUP: required in the event of radical changes to the project&apos;s scope, purpose, or location.
- Split: splitting an original project into two or more independent interventions, each with its own financial framework.
- Merger: consolidating multiple previously separate projects into a single, new, coordinated intervention.</rdfs:comment>
        <rdfs:comment xml:lang="it">Procedura amministrativa e tecnica che permette di aggiornare il corredo informativo di un progetto per garantirne la coerenza con l&apos;evoluzione della decisione amministrativa. Le operazioni si dividono in:
Operazioni semplici che sono eseguibili autonomamente dall&apos;utente abilitato tramite le funzioni di &quot;Modifica&quot; del sistema:
- Variazione del corredo informativo: include l&apos;aggiornamento dei dati anagrafico-descrittivi (es. titolo o descrizione) e/o dei dati finanziari (es. revisione del costo complessivo e del relativo piano di finanziamento) che non alterano l&apos;identità sostanziale del progetto.
Operazioni complesse e assistite che richiedono l&apos;invio di una specifica istanza alla Struttura di supporto tramite la funzione &quot;Invio richiesta modifica&quot;:
- Sostituzione del CUP: necessaria in caso di cambiamenti radicali dell&apos;oggetto, della finalità o della localizzazione dell&apos;intervento.
- Scissione: scomposizione di un progetto originale in due o più interventi indipendenti, ciascuno con il proprio quadro economico.
- Fusione: accorpamento di più progetti precedentemente distinti in un unico nuovo intervento coordinato.</rdfs:comment>
        <rdfs:label xml:lang="it">Atto modifica cup</rdfs:label>
        <rdfs:label xml:lang="en">CUP Amendment Act</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_revoca_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_revoca_cup">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_atto_revoca_cup"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="it">Operazione che annulla la validità di un codice a seguito di una rinuncia formale alla realizzazione dell’intervento o alla perdita del finanziamento. A differenza della cancellazione, presuppone un progetto originariamente valido la cui esecuzione viene interrotta, richiedendo l&apos;inserimento di una motivazione specifica per giustificare il passaggio del CUP allo stato di &quot;revocato&quot;.
Operazioni semplici che sono eseguibili autonomamente dall&apos;utente abilitato tramite le funzioni di &quot;Revoca&quot; del sistema:
- Revoca del corredo informativo: annullamento del progetto per rinuncia al finanziamento, mancata attivazione dell&apos;intervento o accorpamento in altro progetto (previa motivazione da inserire nel sistema).
Operazioni complesse e assistite che richiedono l&apos;invio di una specifica istanza alla Struttura di supporto:
- Revoca per sostituzione: necessaria quando il CUP deve essere chiuso per far posto a un nuovo codice che identifichi meglio l&apos;evoluzione del progetto.
- Revoca post-collegamento: procedura assistita obbligatoria se il CUP da revocare è già stato associato ad altri codici (es. legami tra progettazione e lavori) o se sono già presenti flussi finanziari tracciati.</rdfs:comment>
        <rdfs:comment xml:lang="en">This operation cancels the validity of a code following a formal withdrawal from the project or the loss of funding. Unlike cancellation, it presupposes an originally valid project whose execution is interrupted, requiring the entry of a specific reason to justify the CUP&apos;s transition to &quot;revoked.&quot;
Simple operations that can be performed independently by an authorized user using the system&apos;s &quot;Revocation&quot; functions:
- Revocation of the information package: cancellation of the project due to withdrawal from funding, failure to activate the project, or merger with another project (subject to a reason entered in the system).
Complex and assisted operations that require sending a specific request to the Support Structure:
- Revocation for replacement: required when the CUP must be closed to make way for a new code that better identifies the project&apos;s evolution.
- Post-link revocation: assisted procedure mandatory if the CUP to be revoked has already been associated with other codes (e.g., links between planning and works) or if traceable financial flows already exist.</rdfs:comment>
        <rdfs:label xml:lang="it">Atto revoca cup</rdfs:label>
        <rdfs:label xml:lang="en">CUP revocation act</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_revoca_delega_richiesta_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto_revoca_delega_richiesta_cup">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_atto_revoca_delega_richiesta_cup"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">A measure by which the entity responsible for the investment project formally cancels the digital or operational signature authority on the CUP system granted to a third party. It is divided into:
- Revocation by the Delegate (PF): terminates the technical access of the user responsible for generating the codes.
- Revocation by the Concentrating Entity: dissolves the administrative link between the owner entity and the structure operating on its behalf.</rdfs:comment>
        <rdfs:comment xml:lang="it">Provvedimento con cui il Soggetto titolare del progetto d&apos;investimento annulla formalmente il potere di firma digitale o operativa sul sistema CUP concesso a un terzo. Si distingue in:
- Revoca per il Delegato (PF): interrompe l&apos;accesso tecnico dell&apos;utente incaricato alla generazione dei codici.
- Revoca del Soggetto concentratore: scioglie il legame amministrativo tra l&apos;ente titolare e la struttura che operava per suo conto.</rdfs:comment>
        <rdfs:label xml:lang="it">Atto revoca delega richiesta cup</rdfs:label>
        <rdfs:label xml:lang="en">Revocation of delegation request for CUP</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Categoria_di_intervento -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Categoria_di_intervento">
        <rdfs:comment xml:lang="en">It further specifies the intervention subsector and represents the highest level of detail in the information set. For example, in the case of Sector 01 - Transport Infrastructure, Subsector &quot;Roads&quot;, we will have the intervention categories &quot;Motorways&quot;, &quot;Cycle Paths&quot;, &quot;State Roads&quot;, &quot;Regional, Provincial, and Municipal Roads&quot;, &quot;Rural Roads&quot;, and &quot;Other Road Structures/Infrastructure&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="it">Specifica ulteriormente il Sottosettore di intervento e ne rappresenta il massimo livello di dettaglio nel corredo informativo. Ad esempio, nel caso di Settore 01 - infrastrutture di trasporto, Sottosettore &quot;Stradali&quot;, avremo le Categorie di intervento &quot;Autostrade&quot;, &quot;Piste ciclabili&quot;, &quot;Strade statali&quot;, &quot;Strade regionali, provinciali e comunali&quot;, &quot;Strade rurali&quot;, &quot;Altre strutture/Infrastrutture stradali&quot;.</rdfs:comment>
        <rdfs:label xml:lang="it">Categoria di intervento</rdfs:label>
        <rdfs:label xml:lang="en">Intervention category</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Codice_unico_di_progetto -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Codice_unico_di_progetto">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_soggetto_richiedente_cup"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_utente_richiedente_cup"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_utente_riferimento_cup"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_cup"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">A unique alphanumeric code, consisting of fifteen characters, that identifies each public investment intervention/project. The administrations responsible for implementing these interventions must associate it with the code by requesting its generation in the CUP information system, after being accredited to the system. The CUP makes databases containing information on the implementation status of public investments interoperable. It is included on all administrative and accounting documents, both paper and electronic, relating to public investment projects and must be used in the databases of the various information systems involved in the aforementioned projects (Article 11, paragraph 1, Law No. 3/2003; CIPE Resolution No. 63 of November 26, 2020).</rdfs:comment>
        <rdfs:comment xml:lang="it">Codice alfanumerico univoco, costituito da quindici caratteri, che identifica ciascun intervento/progetto di investimento pubblico, e che deve essere ad esso associato da parte delle amministrazioni titolari, soggetti attuatori, dei medesimi interventi, chiedendone la generazione nel sistema informativo CUP, previo accreditamento allo stesso sistema. Il CUP rende interoperabili le banche dati contenenti informazioni sullo stato di attuazione degli investimenti pubblici È riportato su tutti i documenti amministrativi e contabili, cartacei e informatici, relativi a progetti d’investimento pubblico, e deve essere utilizzato nelle banche dati dei vari sistemi informativi, comunque interessati ai suddetti progetti (art. 11, comma 1, L. n. 3/2003; Delibera CIPE n. 63 del 26 novembre 2020).</rdfs:comment>
        <rdfs:label xml:lang="it">Codice unico di progetto</rdfs:label>
        <rdfs:label xml:lang="en">Unique project code</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Concessione_di_contributi_ad_altri_soggetti -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Concessione_di_contributi_ad_altri_soggetti">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_beneficiario_contributo"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_natura_intervento"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:oneOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/concessione_di_contributi_ad_altri_soggetti"/>
                        </owl:oneOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/infrastruttura_interessata_dal_progetto"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A public investment project consisting of a public entity&apos;s decision to assist a private individual in carrying out a development project (repairing a home after a natural disaster, pursuing a training program) with the entity paying part or all of the expected costs; the CUP is requested by the entity.</rdfs:comment>
        <rdfs:comment xml:lang="it">Progetto d&apos;investimento pubblico che consiste nella decisione di un ente pubblico di aiutare un privato a realizzare un intervento di sviluppo (riparare un’abitazione dopo una calamità naturale, seguire un percorso formativo) con il pagamento, da parte dell’ente, di una parte o della totalità dei costi previsti; il CUP è richiesto dall’ente.</rdfs:comment>
        <rdfs:label xml:lang="it">Concessione di contributi ad altri soggetti</rdfs:label>
        <rdfs:label xml:lang="en">Granting of contributions to other entities</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Concessione_di_incentivi_ad_unità_produttive -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Concessione_di_incentivi_ad_unità_produttive">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_beneficiario_incentivo_unità_produttiva"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_natura_intervento"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:oneOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/concessione_di_incentivi_ad_unità_produttive"/>
                        </owl:oneOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">A public investment project consisting of a public entity&apos;s decision to grant financing to a company for a development project (a new plant, factory maintenance, warehouse expansion), with the entity paying part or all of the company&apos;s projected costs; the CUP is requested by the entity.</rdfs:comment>
        <rdfs:comment xml:lang="it">Progetto d&apos;investimento pubblico che consiste nella decisione di un ente pubblico di concedere un finanziamento a un’impresa per realizzare un intervento di sviluppo (un nuovo stabilimento, la manutenzione di una fabbrica, l’ampliamento di un magazzino) con il pagamento, da parte dell’ente, di parte - o della totalità - dei costi previsti dall’impresa; il CUP è richiesto dall’ente.</rdfs:comment>
        <rdfs:label xml:lang="it">Concessione di incentivi ad unità produttive</rdfs:label>
        <rdfs:label xml:lang="en">Granting incentives to production units</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Cup_collegato_a_master -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Cup_collegato_a_master">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_cup_master_collegato"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">CUP che identifica progetti fra loro collegati in quanto riferiti/riferibili ad un CUP Master. Permette di distinguere lotti o fasi diverse del progetto, garantendo che tutti i flussi finanziari dei &quot;figli&quot; (CUP collegati) siano riconducibili all&apos;investimento unitario del &quot;padre&quot; (CUP master).</rdfs:comment>
        <rdfs:comment xml:lang="en">CUP identifies projects that are linked to each other because they are referred to/can be referred to a Master CUP. It allows you to distinguish different lots or phases of the project, ensuring that all the financial flows of the &quot;children&quot; (linked CUPs) are traceable to the single investment of the &quot;parent&quot; (master CUP).</rdfs:comment>
        <rdfs:label xml:lang="it">Cup collegato a master</rdfs:label>
        <rdfs:label xml:lang="en">Cup connected to master</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Cup_cumulativo -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Cup_cumulativo">
        <rdfs:comment xml:lang="it">CUP afferente a molteplici progetti d’investimento pubblico che sono parte di un unico complesso di interventi; il soggetto responsabile può richiedere un CUP cumulativo quando i progetti consistono nella concessione di contributi a soggetti che non sono unità produttive e in presenza di unico provvedimento amministrativo (delibera, provvedimento dirigenziale, decreto, provvedimento di approvazione di una o più graduatorie, e simili) (Delibera CIPE n. 54 del 22 luglio 2010).</rdfs:comment>
        <rdfs:comment xml:lang="en">CUP relating to multiple public investment projects that are part of a single complex of interventions; the responsible entity may request a cumulative CUP when the projects consist of the granting of contributions to entities that are not production units and in the presence of a single administrative provision (resolution, managerial provision, decree, provision approving one or more rankings, and the like) (CIPE Resolution No. 54 of July 22, 2010).</rdfs:comment>
        <rdfs:label xml:lang="en">Cumulative Cup</rdfs:label>
        <rdfs:label xml:lang="it">Cup cumulativo</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Cup_master -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Cup_master">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ragione_collegamento_master"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_cup_master_collegato"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="it">CUP di riferimento nel caso di progetti con un livello di complessità realizzativa che richiede l’esecuzione mediante un’articolazione di progetti distinti, ma connessi sotto il profilo logico funzionale o temporale; all’atto della richiesta del CUP per ciascuno di essi, i soggetti responsabili registrano il riferimento al CUP relativo alla prima articolazione inserita nel sistema che, così, assurge a CUP Master del progetto globale. Il CUP Master risulta coincidente, dunque, con il codice del progetto che avvia la fase realizzativa dello schema progettuale globale ed è, pertanto, di norma assegnato, come CUP definitivo, al primo fra i progetti integrati che consegue un finanziamento pubblico, al quale è possibile riconnettere tutti i successivi progetti afferenti quello globale. Il collegamento dei singoli CUP di progetto al CUP Master consente la riconducibilità di tale serie di progetti al progetto complesso e quindi la sommabilità delle informazioni relative ai progetti attuativi ([Delibera CIPE n. 143 del 27 dicembre 2002).</rdfs:comment>
        <rdfs:comment xml:lang="en">Reference CUP for projects with a level of implementation complexity that requires execution through a subdivision of distinct projects, yet connected in terms of logic, function, or time. When requesting a CUP for each project, the responsible parties record the reference to the CUP relating to the first subdivision entered into the system, which thus becomes the Master CUP for the overall project. The Master CUP therefore coincides with the project code that initiates the implementation phase of the overall project plan and is therefore normally assigned, as the definitive CUP, to the first of the integrated projects to receive public funding, to which all subsequent projects pertaining to the overall project can be connected. Linking the individual project CUPs to the Master CUP allows this series of projects to be traced back to the overall project and therefore the summation of information relating to the implementation projects ([CIPE Resolution no. 143 of 27 December 2002).</rdfs:comment>
        <rdfs:label xml:lang="en">Cup master</rdfs:label>
        <rdfs:label xml:lang="it">Cup master</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Delega_parziale -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Delega_parziale">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ambito_di_delega"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Delega_totale"/>
        <rdfs:comment xml:lang="it">Modalità di conferimento che riguarda solo casi specifici o ambiti limitati all&apos;interno di una determinata Natura di intervento. A differenza della delega totale, non impedisce al Soggetto responsabile (Soggetto titolare) di continuare a generare autonomamente i codici CUP per i progetti che non rientrano nell&apos;ambito specifico delegato. Un esempio di delega parziale è quello relativo ai soli lavori pubblici realizzati in base a una specifica legge.</rdfs:comment>
        <rdfs:comment xml:lang="en">This delegation method concerns only specific cases or limited areas within a given Nature of Intervention. Unlike full delegation, it does not prevent the Responsible Party (Owner) from continuing to independently generate CUP codes for projects that do not fall within the specific delegated scope. An example of partial delegation is one relating only to public works carried out pursuant to a specific law.</rdfs:comment>
        <rdfs:label xml:lang="it">Delega parziale</rdfs:label>
        <rdfs:label xml:lang="en">Partial delegation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Delega_richiesta_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Delega_richiesta_cup">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Delega_parziale"/>
                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Delega_totale"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_atto_delega_richiesta_cup"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_delega_su_natura_intervento"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_utente_riferimento_concentratore"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_utente_riferimento_titolare_delegante"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/avviso_accettazione_regole_delega"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/TI/TimeIndexedEvent"/>
        <rdfs:comment xml:lang="it">Conferimento, da parte della pubblica amministrazione titolare dell&apos;investimento (e, quindi, responsabile di richiesta cup) del potere di richiesta del CUP ad idoneo soggetto pubblico abilitato (cosiddetto «concentratore») che ne darà evidenza nel sistema, ferme restando le responsabilità del primo per quanto concerne l’obbligo di richiesta di assegnazione del CUP e la correttezza dei dati inseriti nel sistema. (Delibera CIPE n. 63/2020).</rdfs:comment>
        <rdfs:comment xml:lang="en">The public administration responsible for the investment (and, therefore, responsible for requesting the CUP) will grant the power to request the CUP to a suitable authorized public entity (the &quot;concentrator&quot;), which will provide evidence of this in the system. This will remain without prejudice to the former&apos;s responsibilities regarding the obligation to request the CUP assignment and the accuracy of the data entered into the system. (CIPE Resolution No. 63/2020).</rdfs:comment>
        <rdfs:label xml:lang="it">Delega richiesta cup</rdfs:label>
        <rdfs:label xml:lang="en">Delegate cup request</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Delega_totale -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Delega_totale">
        <rdfs:comment xml:lang="it">Modalità di conferimento in cui il Soggetto responsabile (Soggetto titolare) rinuncia completamente alla possibilità di generare autonomamente i codici CUP per la Natura di intervento indicata nella delega. In questo caso, la funzione di richiesta dei codici per quella specifica natura è affidata esclusivamente al Soggetto concentratore fino alla revoca della delega stessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is a method of assignment in which the Responsible Entity (Owner) completely waives the ability to independently generate CUP codes for the type of intervention indicated in the delegation. In this case, the function of requesting codes for that specific type is entrusted exclusively to the Concentrating Entity until the delegation is revoked.</rdfs:comment>
        <rdfs:label xml:lang="it">Delega totale</rdfs:label>
        <rdfs:label xml:lang="en">Full delegation</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Intervento_di_investimento_pubblico -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Intervento_di_investimento_pubblico">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_di_beni"/>
                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Acquisto_o_realizzazione_di_servizi"/>
                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Concessione_di_contributi_ad_altri_soggetti"/>
                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Concessione_di_incentivi_ad_unità_produttive"/>
                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Realizzazione_di_lavori_pubblici"/>
                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Sottoscrizione_iniziale_o_aumento_di_capitale"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_intervento_di_investimento_pubblico"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">Minimum operational unit of a project, at a functional level it represents the part of the information set relating to the Nature, Typology, Sector, Subsector and Category of the project.</rdfs:comment>
        <rdfs:comment xml:lang="it">Unità minima operativa di un progetto, a livello funzionale rappresenta la parte del corredo informativo relativa alla Natura, la Tipologia, il Settore, Il Sottosettore e la Categoria del progetto.</rdfs:comment>
        <rdfs:label xml:lang="it">Intervento di investimento pubblico</rdfs:label>
        <rdfs:label xml:lang="en">Public investment intervention</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Intervento_di_investimento_pubblico_cumulativo -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Intervento_di_investimento_pubblico_cumulativo">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_atto_amministrativo_progetto_cumulativo"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_intervento_di_investimento_pubblico"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_cup"/>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Cup_cumulativo"/>
                    </owl:Restriction>
                </owl:someValuesFrom>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Concessione_di_contributi_ad_altri_soggetti"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/scopo_intervento_cumulativo"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A collection of multiple investment projects that are part of a single set of interventions that allows for the generation of a single CUP when the projects consist of grants to entities that are not production units and the responsible administration has adopted a single specific administrative provision relating to the set of interventions, such as a resolution, a management provision, a decree, a provision approving one or more rankings, and the like.
The cumulative CUP cannot, however, be used in all cases where the &quot;Monit web&quot; monitoring systems of the State General Accounting Office and the &quot;Project Management System&quot; of the Ministry of Economic Development require that each individual intervention be monitored at the individual recipient level. (CIPE Resolution No. 54/2010).</rdfs:comment>
        <rdfs:comment xml:lang="it">Insieme di molteplici progetti d&apos;investimento che fanno parte di un unico complesso di interventi che consente la generazione di un unico CUP qualora i progetti consistono nella concessione di contributi a soggetti che non sono unità produttive e l’amministrazione responsabile ha adottato un unico apposito provvedimento amministrativo, relativo al complesso di interventi, quale ad esempio una delibera, un provvedimento dirigenziale, un decreto, un provvedimento di approvazione di una o più graduatorie, e simili.
Il CUP cumulativo non può comunque essere utilizzato in tutti i casi in cui i sistemi di monitoraggio «Monit web» della Ragioneria generale dello Stato e «Sistema gestione progetti» del Ministero dello sviluppo economico richiedano che ciascun singolo intervento sia monitorato a livello di singolo destinatario. (Delibera Cipe n. 54/2010).</rdfs:comment>
        <rdfs:label xml:lang="en">Cumulative public investment intervention</rdfs:label>
        <rdfs:label xml:lang="it">Intervento di investimento pubblico cumulativo</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Natura_di_intervento -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Natura_di_intervento">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <owl:Class>
                        <owl:oneOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_di_beni"/>
                        </owl:oneOf>
                    </owl:Class>
                    <owl:Class>
                        <owl:oneOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_o_realizzazione_di_servizi"/>
                        </owl:oneOf>
                    </owl:Class>
                    <owl:Class>
                        <owl:oneOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/concessione_di_contributi_ad_altri_soggetti"/>
                        </owl:oneOf>
                    </owl:Class>
                    <owl:Class>
                        <owl:oneOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/concessione_di_incentivi_ad_unità_produttive"/>
                        </owl:oneOf>
                    </owl:Class>
                    <owl:Class>
                        <owl:oneOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/realizzazione_di_lavori_pubblici"/>
                        </owl:oneOf>
                    </owl:Class>
                    <owl:Class>
                        <owl:oneOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/sottoscrizione_iniziale_o_aumento_di_capitale"/>
                        </owl:oneOf>
                    </owl:Class>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="it">Classifica il tipo di progetto e le sue modalità di esecuzione e rappresenta nell&apos;ambito dell&apos;intervento il dato gerarchicamente più importante nel sistema. È il primo dei due livelli (natura e tipologia), tutti obbligatori.
Le 6 Nature di intervento presenti nel sistema sono le seguenti:
01 - Acquisto di beni
02 - Acquisto o realizzazione di servizi
03 - Realizzazione di lavori pubblici (opera ed impiantistica)
06 - Concessione di contributi ad altri soggetti
07 - Concessione di incentivi ad unità produttive
08 - Sottoscrizione iniziale o aumento di capitale sociale (compresi spin off), fondi di rischio o di garanzia.</rdfs:comment>
        <rdfs:comment xml:lang="en">It classifies the type of project and its implementation methods and represents the most important hierarchical data within the system. It is the first of two levels (nature and typology), both of which are mandatory.
The 6 types of intervention present in the system are as follows:
01 - Purchase of goods
02 - Purchase or provision of services
03 - Construction of public works (construction and systems)
06 - Granting of contributions to other entities
07 - Granting of incentives to production units
08 - Initial subscription or increase in share capital (including spin-offs), venture or guarantee funds.</rdfs:comment>
        <rdfs:label xml:lang="it">Natura di intervento</rdfs:label>
        <rdfs:label xml:lang="en">Nature of intervention</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Norma_di_finanziamento -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Norma_di_finanziamento">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/anno_pubblicazione_norma"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/articolo_norma"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/comma_articolo_norma"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/numero_norma"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/tipo_norma"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">An element of the information package that identifies the legislative reference or administrative provision authorizing the disbursement of resources for the project. It allows tracking the use of public funds by linking them to specific laws or programs and is essential for financial reporting and verifying the consistency between allocations and actual commitments. Key components of the financing regulation are the type of regulation, the number and year of publication, and the relevant articles and paragraphs.</rdfs:comment>
        <rdfs:comment xml:lang="it">Elemento del corredo informativo che identifica il riferimento legislativo o il provvedimento amministrativo che autorizza l&apos;erogazione delle risorse per il progetto. Permette di tracciare l&apos;utilizzo dei fondi pubblici legandoli a specifiche leggi o programmi ed è essenziale per la rendicontazione finanziaria e per verificare la coerenza tra stanziamenti e impegni reali. Componenti fondamentali della norma di finanziamento sono il tipo di norma, il numero e l&apos;anno di pubblicazione, gli articoli e i comma di riferimento.</rdfs:comment>
        <rdfs:label xml:lang="en">Financing standard</rdfs:label>
        <rdfs:label xml:lang="it">Norma di finanziamento</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Progetto_di_investimento_pubblico -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Progetto_di_investimento_pubblico">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_indirizzo_o_riferimento"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_soggetto_titolare"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_strumento_di_programmazione"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_tipologia_copertura_finanziaria"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_localizzazione"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/anno_di_decisione"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/avviso_legge_obiettivo"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/costo_del_progetto"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/importo_finanziamento_pubblico"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">A set of interconnected actions or support instruments for the implementation of a public investment project consisting of four requirements: 1) the presence of a public decision-maker; 2) financing—even partial, direct, or indirect—with public resources or through the use of public facilities for the project&apos;s implementation; 3) the aforementioned actions or instruments have a common objective of economic and social development; 4) to be achieved within a specified timeframe. The Project can be classified according to its nature: public works; granting of incentives; granting of contributions; purchase of goods; purchase or provision of services; capital increases (CIPE Resolutions Nos. 63/2020, 143/2020).</rdfs:comment>
        <rdfs:comment xml:lang="it">Complesso di azioni o di strumenti di sostegno collegati fra loro per la realizzazione di un intervento di investimento pubblico costituito da quattro requisiti: 1) presenza di un decisore pubblico; 2) finanziamento - anche parziale, diretto o indiretto - con risorse pubbliche o con l’uso di strutture pubbliche per la realizzazione del progetto; 3) le azioni o gli strumenti suddetti hanno un comune obiettivo di sviluppo economico e sociale; 4) da raggiungere entro un tempo specificato. Il Progetto può essere classificato in funzione della sua natura: lavori pubblici; concessione incentivi; concessione contributi; acquisto di beni; acquisto o realizzazione di servizi; aumenti di capitale (Delibere CIPE nn. 63/2020, 143/2020). </rdfs:comment>
        <rdfs:label xml:lang="it">Progetto di investimento pubblico</rdfs:label>
        <rdfs:label xml:lang="en">Public investment project</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Realizzazione_di_lavori_pubblici -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Realizzazione_di_lavori_pubblici">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_natura_intervento"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:oneOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/realizzazione_di_lavori_pubblici"/>
                        </owl:oneOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/avviso_infrastruttura_singola_multipla"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/oggetto_progettuale"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A public investment project consisting of a decision by an entity (contracting authority) to commission an infrastructure project (a new road, maintenance of a school, expansion of a hospital), with the contracting authority paying the company or companies that carry it out. The CUP is generally associated with the construction of the functional lot, where applicable; the CUP is requested by the contracting authority.</rdfs:comment>
        <rdfs:comment xml:lang="it">Progetto d&apos;investimento pubblico che consiste nella decisione di un ente (stazione appaltante) di far realizzare un intervento infrastrutturale (una nuova strada, la manutenzione di una scuola, l’ampliamento di un ospedale) con il pagamento, da parte della stazione appaltante, della impresa/delle imprese che lo realizzano. Il CUP è generalmente associato alla realizzazione del lotto funzionale ove previsto; il CUP è richiesto dalla stazione appaltante.</rdfs:comment>
        <rdfs:label xml:lang="en">Construction of public works</rdfs:label>
        <rdfs:label xml:lang="it">Realizzazione di lavori pubblici</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Settore_di_intervento -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Settore_di_intervento">
        <rdfs:comment xml:lang="it">Individua le categorie omogenee all&apos;interno delle quali ricomprendere gli interventi in base alla loro destinazione. È il primo dei tre livelli (settore, sottosettore e categoria), tutti obbligatori. Gli 11 settori di intervento presenti nel sistema sono i seguenti:
01 - infrastrutture di trasporto
02 - infrastrutture ambientali e risorse idriche
03 - infrastrutture del settore energetico
04 - infrastrutture per l&apos;attrezzatura di aree produttive
05 - infrastrutture sociali
06 - opere, impianti ed attrezzature per attività produttive, e la ricerca e l&apos;impresa sociale
07 - infrastrutture per telecomunicazioni e tecnologie informatiche
08 - ricerca sviluppo tecnologico ed innovazione
09 - servizi alle imprese
10 - servizi per la p.a. e per la collettività
11 - istruzione, formazione e sostegni per il mercato del lavoro.</rdfs:comment>
        <rdfs:comment xml:lang="en">It identifies homogeneous categories within which interventions are classified based on their intended purpose. This is the first of three levels (sector, subsector, and category), all of which are mandatory. The 11 intervention sectors present in the system are as follows:
01 - transport infrastructure
02 - environmental infrastructure and water resources
03 - energy sector infrastructure
04 - infrastructure for the equipment of production areas
05 - social infrastructure
06 - works, facilities, and equipment for production activities, research, and social enterprise
07 - telecommunications and information technology infrastructure
08 - research, technological development, and innovation
09 - business services
10 - public administration and community services
11 - education, training, and labor market support.</rdfs:comment>
        <rdfs:label xml:lang="en">Sector of intervention</rdfs:label>
        <rdfs:label xml:lang="it">Settore di intervento</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Soggetto_accreditato_sistema_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Soggetto_accreditato_sistema_cup">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_area_soggetto_accreditato"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_categoria_soggetto_accreditato"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_natura_giuridica_soggetto_accreditato"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_sottocategoria_soggetto_accreditato"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/COV/Organization"/>
        <rdfs:comment xml:lang="en">An entity that has completed the registration and validation process on the CUP System portal. This is necessary to appoint contact persons and enable users to generate codes. The entity accredited in the CUP system acts as the legal entity responsible for the system, ensuring that those operating on behalf of an officially recognized institution.</rdfs:comment>
        <rdfs:comment xml:lang="it">Ente che ha completato l&apos;iter di registrazione e validazione presso il portale Sistema CUP. Questa è la condizione necessaria per poter nominare i referenti e abilitare gli utenti alla generazione dei codici. Il Soggetto accreditato nel sistema CUP funge da entità giuridica responsabile verso il sistema, garantendo che chi opera lo faccia per conto di un&apos;istituzione ufficialmente riconosciuta.</rdfs:comment>
        <rdfs:label xml:lang="en">Accredited subject of the CUP system</rdfs:label>
        <rdfs:label xml:lang="it">Soggetto accreditato sistema cup</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Soggetto_attuatore_interventi_PNRR -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Soggetto_attuatore_interventi_PNRR">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/COV/Organization"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Public or private entity that implements the interventions envisaged by the PNRR (art. 1, paragraph 4, letter o), Legislative Decree no. 77/2021).</rdfs:comment>
        <rdfs:comment xml:lang="it">Soggetto pubblico o privato che provvede alla realizzazione degli interventi previsti dal PNRR (art. 1, comma 4, lett. o), DL n. 77/2021).</rdfs:comment>
        <rdfs:label xml:lang="en">Implementing body for PNRR interventions</rdfs:label>
        <rdfs:label xml:lang="it">Soggetto attuatore interventi PNRR</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Soggetto_concentratore -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Soggetto_concentratore">
        <rdfs:comment xml:lang="en">Public entity authorized to perform the CUP request functions upon delegation by the owner, based on specific agreements and providing evidence of this in the system, without prejudice to the owner&apos;s responsibilities regarding the obligation to request assignment of the CUP and the accuracy of the data entered into the system (CIPE Resolution no. 63 of 26 November 2020).</rdfs:comment>
        <rdfs:comment xml:lang="it">Soggetto pubblico abilitato a svolgere le funzioni di richiesta del CUP su delega del soggetto titolare, sulla base di specifici accordi e dandone evidenza nel sistema, ferme restando le responsabilità del titolare per quanto concerne l’obbligo di richiesta di assegnazione del CUP e la correttezza dei dati inseriti nel sistema (Delibera CIPE n. 63 del 26 novembre 2020).</rdfs:comment>
        <rdfs:label xml:lang="en">Concentrating subject</rdfs:label>
        <rdfs:label xml:lang="it">Soggetto concentratore</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Soggetto_richiedente_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Soggetto_richiedente_cup">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Soggetto_concentratore"/>
                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Soggetto_titolare_progetto_investimento"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="it">Soggetto che svolge le funzioni di richiesta del codice all&apos;interno del sistema CUP; è immutabile nel tempo e solitamente coincide con il Soggetto responsabile del progetto (Soggetto titolare), in caso di delega il ruolo è assunto dal Soggetto concentratore.</rdfs:comment>
        <rdfs:comment xml:lang="en">The entity that performs the code request functions within the CUP system; it is unchangeable over time and usually coincides with the entity responsible for the project (Owner). In the event of delegation, the role is assumed by the Concentrating Entity.</rdfs:comment>
        <rdfs:label xml:lang="en">Applicant subject CUP</rdfs:label>
        <rdfs:label xml:lang="it">Soggetto richiedente cup</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Soggetto_titolare_progetto_investimento -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Soggetto_titolare_progetto_investimento">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_delegante_richiesta_cup"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_delegato_richiesta_cup"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Soggetto_concentratore"/>
                                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Soggetto_richiedente_cup"/>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Entity responsible for implementing the interventions and, therefore, responsible for requesting the CUP:
a. For the construction of public works: the contracting authority, the concessionaire, or the Municipality;
b. For the granting of incentives to production units: the public entity responsible for granting public resources or its delegate (including a private one); 
c. For the granting of aid to entities other than production units: the public entity holding the concession; 
d. For the purchase of goods and services or shareholdings/capital contributions: the public entity responsible for the spending decision; 
e. For the provision of services: the public entity implementing the project.
The project owner and the CUP requester are the same, except in the case of a CUP request by proxy granted to the &quot;concentrator&quot; entity.
(CIPE Resolution no. 143 of 27 December 2002, referred to by CIPE Resolution no. 63 of 26 November 2020).</rdfs:comment>
        <rdfs:comment xml:lang="it">Soggetto cui compete l&apos;attuazione degli interventi e, quindi, responsabile della richiesta del CUP:
a. per la realizzazione dei lavori pubblici: la stazione appaltante, il concessionario o il Comune;
b. per la concessione di incentivi a unità produttive: il soggetto pubblico cui spetta la competenza per la concessione delle risorse pubbliche o suo delegato (anche privato); 
c. per la concessione di aiuti a soggetti diversi dalle unità produttive: l’Ente pubblico titolare della concessione; 
d. per l’acquisto di beni e servizi o partecipazioni azionare/conferimenti capitale: l’ente pubblico titolare della decisione di spesa; 
e. per la realizzazione di servizi: l’ente pubblico che realizza il progetto.
Soggetto titolare del progetto e soggetto richiedente il CUP coincidono salvo il caso di richiesta CUP su delega rilasciata al soggetto “concentratore”.
(Delibera CIPE n. 143 del 27 dicembre 2002, richiamata dalla Delibera CIPE n. 63 del 26 novembre 2020).</rdfs:comment>
        <rdfs:label xml:lang="en">Entity holding the investment project</rdfs:label>
        <rdfs:label xml:lang="it">Soggetto titolare progetto investimento</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Sottoscrizione_iniziale_o_aumento_di_capitale -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Sottoscrizione_iniziale_o_aumento_di_capitale">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_beneficiario_partecipazione_conferimento"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_finalità_partecipazione_conferimento"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_natura_intervento"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:oneOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/sottoscrizione_iniziale_o_aumento_di_capitale"/>
                        </owl:oneOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">A public investment project consisting of a public entity&apos;s decision to participate in a capital increase (or the formation of a new company, etc.) with the entity paying the costs associated with the operation (capital payment, etc.); the CUP is requested by the entity&quot; (Resolution no. 63 of November 26, 2020).</rdfs:comment>
        <rdfs:comment xml:lang="it">Progetto d&apos;investimento pubblico che consiste nella decisione di un ente pubblico di partecipare a un aumento di capitale sociale (o di costituzione di una nuova società ecc.) con il pagamento, da parte dell’ente, dei costi connessi all’operazione (versamento del capitale, ecc.); il CUP è richiesto dall’ente” (Delibera n. 63 del 26 novembre 2020).</rdfs:comment>
        <rdfs:label xml:lang="en">Initial subscription or capital increase</rdfs:label>
        <rdfs:label xml:lang="it">Sottoscrizione iniziale o aumento di capitale</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Sottosettore_di_intervento -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Sottosettore_di_intervento">
        <rdfs:comment xml:lang="it">Identifica il sottolivello di Settore di intervento. Consente di raggruppare i progetti per ambiti omogenei. Ad esempio, nel caso di Settore 01 - infrastrutture di trasporto i Sottosettori di intervento saranno &quot;Aeroportuali&quot;, &quot;Ferrovie&quot;, &quot;Marittime, lacuali e fluviali&quot;, &quot;Stradali&quot;, &quot;Trasporto urbano&quot;, &quot;Trasporti multimodali e altre modalità di trasporto&quot;.</rdfs:comment>
        <rdfs:comment xml:lang="en">Identifies the sub-level of the Sector of Intervention. It allows projects to be grouped into homogeneous areas. For example, in the case of Sector 01 - Transport Infrastructure, the Sub-Sectors of Intervention will be &quot;Airports&quot;, &quot;Railways&quot;, &quot;Maritime, Lake and River Transport&quot;, &quot;Roads&quot;, &quot;Urban Transport&quot;, and &quot;Multimodal Transport and Other Modes of Transport&quot;.</rdfs:comment>
        <rdfs:label xml:lang="it">Sottosettore di intervento</rdfs:label>
        <rdfs:label xml:lang="en">Subsector of intervention</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_attivo_di_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_attivo_di_cup">
        <rdfs:comment xml:lang="en">CUP status of a project in the planning/implementation phase (CIPE Resolution no. 63 of 26 November 2020).</rdfs:comment>
        <rdfs:comment xml:lang="it">Stato del CUP di un progetto in fase di programmazione/attuazione (Delibera CIPE n. 63 del 26 novembre 2020).</rdfs:comment>
        <rdfs:label xml:lang="en">Active state of cup</rdfs:label>
        <rdfs:label xml:lang="it">Stato attivo di cup</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_cancellato_di_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_cancellato_di_cup">
        <rdfs:comment xml:lang="en">CUP status cancelled as it was generated due to a material error (CIPE Resolution no. 63 of 26 November 2020).</rdfs:comment>
        <rdfs:comment xml:lang="it">Stato del CUP cancellato in quanto generato per errore materiale (Delibera CIPE n. 63 del 26 novembre 2020).</rdfs:comment>
        <rdfs:label xml:lang="en">Cup status deleted</rdfs:label>
        <rdfs:label xml:lang="it">Stato cancellato di cup</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_chiuso_di_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_chiuso_di_cup">
        <rdfs:comment xml:lang="en">CUP status closed when the project is physically completed, all payments and collections have been made and the procedural process is also completed (CIPE Resolution no. 63 of 26 November 2020).</rdfs:comment>
        <rdfs:comment xml:lang="it">Stato del CUP chiuso quando il progetto è completato dal punto di vista fisico, tutti i pagamenti e gli incassi sono stati eseguiti ed è completato anche l’iter procedurale (Delibera CIPE n. 63 del 26 novembre 2020).</rdfs:comment>
        <rdfs:label xml:lang="en">Closed state of cup</rdfs:label>
        <rdfs:label xml:lang="it">Stato chiuso di cup</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_coerente_programma_spesa_di_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_coerente_programma_spesa_di_cup">
        <rdfs:comment xml:lang="it">Stato del CUP allegato ad un atto amministrativo di finanziamento/autorizzazione di investimenti pubblici, la cui classificazione, riportata nell’anagrafica del sistema CUP, rispetta i vincoli disposti dalla normativa, che istituisce e regola il programma di spesa ai sensi del quale viene emanato l’atto stesso (Delibera CIPE n. 63 del 26 novembre 2020).</rdfs:comment>
        <rdfs:comment xml:lang="en">Status of the CUP attached to an administrative act for the financing/authorization of public investments, whose classification, reported in the CUP system registry, complies with the constraints set by the legislation, which establishes and regulates the spending program pursuant to which the act itself is issued (CIPE Resolution no. 63 of 26 November 2020).</rdfs:comment>
        <rdfs:label xml:lang="en">Consistent state of CUP spending program</rdfs:label>
        <rdfs:label xml:lang="it">Stato coerente programma spesa di cup</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_completo_di_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_completo_di_cup">
        <owl:equivalentClass rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_valido_di_Cup"/>
        <rdfs:comment xml:lang="it">Stato del CUP che possiede un corredo informativo integro e validato dal sistema. Questo prevede la compilazione di tutti i campi obbligatori, inclusi i dati finanziari e la localizzazione. Tutte queste informazioni sono pubbliche, ad eccezione di quelle riguardanti l’utente che ha richiesto il codice.</rdfs:comment>
        <rdfs:comment xml:lang="en">Status of the CUP having complete and system-validated information. This requires completing all mandatory fields, including financial data and location. All this information is public, except for that relating to the user who requested the code.</rdfs:comment>
        <rdfs:label xml:lang="en">Complete state of cup</rdfs:label>
        <rdfs:label xml:lang="it">Stato completo di cup</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_corretto_di_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_corretto_di_cup">
        <rdfs:comment xml:lang="it">Stato del CUP definitivo allegato ad un atto di finanziamento/autorizzazione di investimenti pubblici, che possiede le caratteristiche necessarie per identificare un intervento/progetto, che l’amministrazione titolare manifesta di voler realizzare (Delibera CIPE n. 63 del 26 novembre 2020).</rdfs:comment>
        <rdfs:comment xml:lang="en">Status of the final CUP attached to a public investment financing/authorization act, which has the necessary characteristics to identify an intervention/project, which the owner administration declares it wishes to implement (CIPE Resolution no. 63 of 26 November 2020).</rdfs:comment>
        <rdfs:label xml:lang="en">Correct cup status</rdfs:label>
        <rdfs:label xml:lang="it">Stato corretto di cup</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_di_atto_di_finanziamento -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_di_atto_di_finanziamento">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_stato_di_atto_di_finanziamento"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/TI/TimeIndexedEvent"/>
        <rdfs:comment xml:lang="en">State that aggregates the conditions of correctness, consistency, and issuance of the administrative act that provides public funding or authorizes the implementation of specific public investment projects; it necessarily includes the CUP (Single Project Code) as an essential element, under penalty of nullity, to ensure the traceability and transparency of public investments.</rdfs:comment>
        <rdfs:comment xml:lang="it">Stato che aggrega le condizioni di correttezza, coerenza ed emanazione dell&apos;atto amministrativo che dispone il finanziamento pubblico o autorizza l&apos;esecuzione di specifici progetti di investimento pubblico; include necessariamente il CUP (Codice Unico di Progetto) come elemento essenziale, pena la nullità, per garantire tracciabilità e trasparenza degli investimenti pubblici.</rdfs:comment>
        <rdfs:label xml:lang="it">Stato di atto di finanziamento</rdfs:label>
        <rdfs:label xml:lang="en">Status of financing act</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_di_coerenza_di_atto_di_finanziamento -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_di_coerenza_di_atto_di_finanziamento">
        <rdfs:comment xml:lang="it">La condizione di un atto amministrativo di finanziamento/autorizzazione di investimenti pubblici, la cui classificazione, riportata nell’anagrafica del sistema CUP, rispetta i vincoli disposti dalla normativa che istituisce e regola il programma di spesa ai sensi del quale viene emanato l’atto stesso.</rdfs:comment>
        <rdfs:comment xml:lang="en">The condition of an administrative act financing/authorizing public investments, whose classification, reported in the CUP system registry, complies with the constraints set forth in the legislation establishing and regulating the spending program under which the act itself is issued.</rdfs:comment>
        <rdfs:label xml:lang="en">State of coherence of financing act</rdfs:label>
        <rdfs:label xml:lang="it">Stato di coerenza di atto di finanziamento</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_di_correttezza_di_atto_di_finanziamento -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_di_correttezza_di_atto_di_finanziamento">
        <rdfs:comment xml:lang="it">La condizione di un atto amministrativo di finanziamento/autorizzazione di investimenti pubblici che possiede le caratteristiche necessarie per identificare un intervento/progetto, che l’amministrazione titolare manifesta di voler realizzare. </rdfs:comment>
        <rdfs:comment xml:lang="en">The condition of an administrative act of financing/authorization of public investments that possesses the characteristics necessary to identify an intervention/project, which the owner administration declares it wishes to implement.</rdfs:comment>
        <rdfs:label xml:lang="it">Stato di correttezza di atto di finanziamento</rdfs:label>
        <rdfs:label xml:lang="en">Status of correctness of financing act</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_di_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_di_cup">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/l0/hasMember"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Storia_di_cup"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/TI/TimeIndexedEvent"/>
        <rdfs:comment xml:lang="en">Administrative and technical status of the CUP within the Project Registry: active; cancelled; closed; provisional; consistent with the spending plan; complete; correct; valid; revoked.</rdfs:comment>
        <rdfs:comment xml:lang="it">Condizione amministrativa e tecnica del CUP all&apos;interno dell&apos;Anagrafe Progetti: attivo; cancellato; chiuso; provvisorio; coerente con il programma di spesa; completo; corretto; valido; revocato.</rdfs:comment>
        <rdfs:label xml:lang="en">Cup status</rdfs:label>
        <rdfs:label xml:lang="it">Stato di cup</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_di_emanazione_di_atto_di_finanziamento -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_di_emanazione_di_atto_di_finanziamento">
        <rdfs:comment xml:lang="it">La condizione di un atto amministrativo di finanziamento/autorizzazione di investimenti pubblici a cui è associato uno Stato attivo di CUP, relativo ad un progetto in fase di programmazione/attuazione.</rdfs:comment>
        <rdfs:comment xml:lang="en">The condition of an administrative act of financing/authorization of public investments to which an active CUP status is associated, relating to a project in the planning/implementation phase.</rdfs:comment>
        <rdfs:label xml:lang="en">State of issue of financing act</rdfs:label>
        <rdfs:label xml:lang="it">Stato di emanazione di atto di finanziamento</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_provvisorio_di_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_provvisorio_di_cup">
        <rdfs:comment xml:lang="en">Optional CUP status, with no administrative relevance, which some administrations use to record the project from the very beginning of the project idea, when the investment cost and financing are not yet imaginable. Technically, the code string contains one fewer character than the final CUP, and the first three are characterized by the letters PROV, for example: PROV0000019464 (CIPE Resolution no. 63 of November 26, 2020).</rdfs:comment>
        <rdfs:comment xml:lang="it">Stato del CUP facoltativo, e privo di rilevanza amministrativa, che alcune amministrazioni utilizzano per censire il progetto sin dalla nascita dell’idea progettuale, quando ancora non sono immaginabili i valori riguardanti il costo e il finanziamento dell’investimento. Dal punto di vista tecnico, la stringa di codice contiene un carattere in meno del CUP definitivo e i primi tre sono caratterizzati dalle lettere PROV esempio: PROV0000019464 (Delibera CIPE n. 63 del 26 novembre 2020).</rdfs:comment>
        <rdfs:label xml:lang="en">Provisional status of cup</rdfs:label>
        <rdfs:label xml:lang="it">Stato provvisorio di cup</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_revocato_di_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_revocato_di_cup">
        <rdfs:comment xml:lang="en">CUP status revoked because the entity responsible for the project decides not to implement it before its closure (CIPE Resolution no. 63 of 26 November 2020).</rdfs:comment>
        <rdfs:comment xml:lang="it">Stato del CUP revocato perché il soggetto titolare dell’intervento decide di non realizzarlo prima della sua chiusura (Delibera CIPE n. 63 del 26 novembre 2020).</rdfs:comment>
        <rdfs:label xml:lang="en">CUP status revoked</rdfs:label>
        <rdfs:label xml:lang="it">Stato revocato di cup</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_valido_di_Cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Stato_valido_di_Cup">
        <rdfs:comment xml:lang="it">Stato del CUP definitivo generato ed esistente all’interno del sistema informativo CUP (Delibera CIPE n. 63 del 26 novembre 2020).</rdfs:comment>
        <rdfs:comment xml:lang="en">Status of the final CUP generated and existing within the CUP information system (CIPE Resolution no. 63 of 26 November 2020).</rdfs:comment>
        <rdfs:label xml:lang="it">Stato valido di cup</rdfs:label>
        <rdfs:label xml:lang="en">Valid cup status</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Storia_di_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Storia_di_cup">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_stato_di_cup"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/onto/l0/Sequence"/>
        <rdfs:comment xml:lang="en">A chronological and immutable log of all changes, additions, and status changes affecting a given CUP from its generation until its closure or revocation. It tracks each event, the operator that generated it, and the time it occurred.</rdfs:comment>
        <rdfs:comment xml:lang="it">Registro cronologico e immutabile di tutte le variazioni, integrazioni e passaggi di stato che hanno interessato un determinato CUP dalla sua generazione fino alla chiusura o revoca. Tiene traccia di ogni evento, dell&apos;operatore che lo genera e del momento in cui viene generato.</rdfs:comment>
        <rdfs:label xml:lang="en">History of cup</rdfs:label>
        <rdfs:label xml:lang="it">Storia di cup</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Strumento_di_programmazione -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Strumento_di_programmazione">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Strumento_di_programmazione_libero"/>
                    <rdf:Description rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_strumento_di_programmazione"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An implementation tool for managing and allocating financial resources to achieve specific objectives based on a specific annual or three-year plan.</rdfs:comment>
        <rdfs:comment xml:lang="it">Strumento di attuazione per la gestione e l&apos;allocazione delle risorse finanziarie con la finalità di realizzare obiettivi specifici sulla base di un determinato piano annuale o triennale.</rdfs:comment>
        <rdfs:label xml:lang="en">Programming tool</rdfs:label>
        <rdfs:label xml:lang="it">Strumento di programmazione</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Strumento_di_programmazione_libero -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Strumento_di_programmazione_libero">
        <owl:disjointWith rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_strumento_di_programmazione"/>
        <rdfs:comment xml:lang="it">Si tratta della sottocategoria residuale di strumento di programmazione e rappresenta il dettaglio descrittivo o il nome specifico dello strumento qualora non sia riconducibile a una categoria standard o necessiti di ulteriore specificazione. Consente all&apos;utente di inserire testualmente il nome del piano, dell&apos;accordo o del programma specifico e fornisce flessibilità al corredo informativo, permettendo di tracciare strumenti di programmazione locali o specifici che non rientrano nelle tipologie generali predefinite.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is the residual subcategory of programming tools and represents the descriptive detail or specific name of the tool if it doesn&apos;t fit into a standard category or requires further specification. It allows the user to enter the name of the specific plan, agreement, or program and provides flexibility in the information set, allowing for the tracking of local or specific programming tools that don&apos;t fit into the predefined general typologies.</rdfs:comment>
        <rdfs:label xml:lang="en">Free programming tool</rdfs:label>
        <rdfs:label xml:lang="it">Strumento di programmazione libero</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Subinvestimento_PNRR -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Subinvestimento_PNRR">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/prevede_subinvestimento_pnrr"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="it">Articolazione di dettaglio della Tematica PNRR che identifica la specifica linea di finanziamento a cui il progetto è collegato; la sua selezione, obbligatoria per i progetti PNRR, definisce il perimetro operativo dell&apos;intervento e vincola la scelta dei Target PNRR di progetto ai soli obiettivi associati a quella specifica misura.</rdfs:comment>
        <rdfs:comment xml:lang="en">Detailed breakdown of the PNRR Theme that identifies the specific funding line to which the project is linked; its selection, mandatory for PNRR projects, defines the operational scope of the intervention and limits the choice of PNRR project targets to the objectives associated with that specific measure.</rdfs:comment>
        <rdfs:label xml:lang="en">PNRR sub-investment</rdfs:label>
        <rdfs:label xml:lang="it">Sub-investimento PNRR</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Target_PNRR -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Target_PNRR">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/prevede_target_pnrr"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="en">It represents the quantitative or qualitative objective (milestone/target) defined at the national level for a specific PNRR sub-investment; it serves as a benchmark for measuring the Plan&apos;s progress and constitutes the hub to which the individual PNRR project targets are linked for reporting results.</rdfs:comment>
        <rdfs:comment xml:lang="it">Rappresenta l&apos;obiettivo quantitativo o qualitativo (milestone/target) definito a livello nazionale per un determinato Sub-investimento PNRR; funge da parametro di riferimento per misurare l&apos;avanzamento del Piano e costituisce il nodo a cui si agganciano i singoli Target PNRR di progetto per la rendicontazione dei risultati.</rdfs:comment>
        <rdfs:label xml:lang="en">PNRR Target</rdfs:label>
        <rdfs:label xml:lang="it">Target PNRR</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Target_PNRR_di_progetto -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Target_PNRR_di_progetto">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_target_pnrr"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_target_pnrr_di_progetto"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/data_raggiungimento_target_di_progetto"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/valore_target_di_progetto"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:comment xml:lang="it">Costituisce la quota parte dell&apos;obiettivo nazionale (Target PNRR) che il singolo Progetto di Investimento Pubblico si impegna a realizzare; è il valore specifico inserito nel corredo informativo del CUP che permette di verificare il contributo puntuale del progetto al raggiungimento dei traguardi previsti dal monitoraggio europeo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This represents the share of the national objective (PNRR Target) that each Public Investment Project commits to achieving; it is the specific value included in the CUP information package that allows verification of the project&apos;s specific contribution to achieving the goals set by European monitoring.</rdfs:comment>
        <rdfs:label xml:lang="en">PNRR project targets</rdfs:label>
        <rdfs:label xml:lang="it">Target PNRR di progetto</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tematica_PNRR -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tematica_PNRR">
        <rdfs:comment xml:lang="it">Campo del corredo informativo del Progetto di investimento pubblico che identifica l&apos;area strategica dell&apos;intervento, obbligatorio per i progetti che beneficiano di fondi PNRR; la sua compilazione comporta l&apos;attivazione automatica dei campi relativi al Sub-investimento e ai Target di progetto per il monitoraggio europeo.</rdfs:comment>
        <rdfs:comment xml:lang="en">This field in the Public Investment Project information package identifies the strategic area of ​​intervention, mandatory for projects receiving PNRR funding. Completing this field automatically activates the fields for Sub-investment and Project Targets for European monitoring.</rdfs:comment>
        <rdfs:label xml:lang="en">PNRR Theme</rdfs:label>
        <rdfs:label xml:lang="it">Tematica PNRR</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_area_soggetto_accreditato -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_area_soggetto_accreditato">
        <rdfs:comment xml:lang="it">Campo che definisce l’ambito di competenza funzionale o settoriale prevalente del Soggetto accreditato al Sistema CUP (es. Sanità, Istruzione, Trasporti). Permette al sistema di associare il Soggetto ai rispettivi settori di intervento e agevola i flussi di monitoraggio verso le amministrazioni centrali competenti per materia.</rdfs:comment>
        <rdfs:comment xml:lang="en">This field defines the primary functional or sectoral area of ​​expertise of the entity accredited to the CUP System (e.g., Healthcare, Education, Transportation). It allows the system to associate the entity with its respective sectors of intervention and facilitates monitoring flows to the central administrations responsible for the relevant subject matter.</rdfs:comment>
        <rdfs:label xml:lang="it">Tipo area soggetto accreditato</rdfs:label>
        <rdfs:label xml:lang="en">Type of accredited subject area</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_categoria_soggetto_accreditato -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_categoria_soggetto_accreditato">
        <rdfs:comment xml:lang="it">Campo del corredo informativo che definisce il macro-settore di appartenenza del Soggetto accreditato al Sistema CUP (es. Amministrazioni Centrali, Enti Locali, Società Pubbliche). Rappresenta il primo livello di classificazione del Soggetto e determina l’ambito istituzionale in cui l’ente opera all&apos;interno dell&apos;Anagrafe Soggetti.</rdfs:comment>
        <rdfs:comment xml:lang="en">This information field defines the macro-sector to which the entity accredited to the CUP System belongs (e.g., Central Administrations, Local Authorities, Public Companies). It represents the first level of entity classification and determines the institutional context in which the entity operates within the Register of Individuals.</rdfs:comment>
        <rdfs:label xml:lang="en">Accredited subject category type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo categoria soggetto accreditato</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_di_finalità_partecipazione_conferimento -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_di_finalità_partecipazione_conferimento">
        <rdfs:comment xml:lang="it">Campo del corredo informativo, attivato esclusivamente per i progetti con Natura &quot;Sottoscrizione iniziale o aumento di capitale sociale (compresi spin off), fondi di rischio o di garanzia&quot;, che specifica lo scopo istituzionale o economico dell&apos;operazione finanziaria. Serve a distinguere se il conferimento di capitale o la creazione di un fondo sia finalizzato al sostegno di attività produttive, alla ricerca e sviluppo (spin-off) o alla gestione di rischi finanziari.</rdfs:comment>
        <rdfs:comment xml:lang="en">This field in the information package, activated exclusively for projects with the &quot;Initial subscription or increase in share capital (including spin-offs), venture or guarantee funds&quot; nature, specifies the institutional or economic purpose of the financial transaction. It is used to distinguish whether the capital injection or the creation of a fund is intended to support production activities, research and development (spin-offs), or financial risk management.</rdfs:comment>
        <rdfs:label xml:lang="it">Tipo di finalità partecipazione conferimento</rdfs:label>
        <rdfs:label xml:lang="en">Type of purpose participation contribution</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_motivazione_assenza_CUP_di_progettazione -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_motivazione_assenza_CUP_di_progettazione">
        <rdfs:comment xml:lang="it">Insieme delle causali selezionabili nel sistema per giustificare la mancata associazione di un cup di progettazione con Natura 2 ad un cup di Natura 3</rdfs:comment>
        <rdfs:comment xml:lang="en">Set of reasons that can be selected in the system to justify the failure to associate a Nature 2 design CUP with a Nature 3 CUP</rdfs:comment>
        <rdfs:label xml:lang="it">Tipo motivazione assenza CUP di progettazione</rdfs:label>
        <rdfs:label xml:lang="en">Type of reason for absence of CUP planning</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_natura_giuridica_soggetto_accreditato -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_natura_giuridica_soggetto_accreditato">
        <rdfs:comment xml:lang="en">Attribute that identifies the legal status of the entity accredited to the CUP system (e.g., Public Economic Entity, Constitutional Body, Joint Stock Company). This information is essential for defining the legal provisions (public or private) to which the entity is subject and, consequently, its powers in the context of spending procedures.</rdfs:comment>
        <rdfs:comment xml:lang="it">Attributo che identifica la veste legale del Soggetto accreditato al Sistema CUP (es. Ente Pubblico Economico, Organo Costituzionale, Società per Azioni). Questo dato è fondamentale per definire le norme di diritto (pubblico o privato) a cui l&apos;ente è soggetto e, conseguentemente, le sue facoltà nell&apos;ambito dei procedimenti di spesa.</rdfs:comment>
        <rdfs:label xml:lang="it">Tipo natura giuridica soggetto accreditato</rdfs:label>
        <rdfs:label xml:lang="en">Type of legal nature of accredited entity</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_sottocategoria_soggetto_accreditato -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_sottocategoria_soggetto_accreditato">
        <rdfs:comment xml:lang="en">A detailed element that further specifies the Category to which the CUP System-accredited entity belongs for more precise profiling (e.g., within the &quot;Local Authorities&quot; category, it distinguishes between Municipalities, Provinces, or Metropolitan Cities). It serves to group entities by similarity of administrative functions and territorial competences.</rdfs:comment>
        <rdfs:comment xml:lang="it">Elemento di dettaglio che specifica ulteriormente la Categoria di appartenenza del Soggetto accreditato al Sistema CUP per una profilazione più precisa (es. all&apos;interno della categoria &quot;Enti Locali&quot;, distingue tra Comuni, Province o Città Metropolitane). Serve a raggruppare i soggetti per affinità di funzioni amministrative e competenze territoriali.</rdfs:comment>
        <rdfs:label xml:lang="en">Accredited entity subcategory type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo sottocategoria soggetto accreditato</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_strumento_di_programmazione -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipo_strumento_di_programmazione">
        <rdfs:comment xml:lang="it">Si tratta di una sottocategoria di strumento di programmazione che si basa su un elenco predefinito (dominio di valori) fornito dal sistema CUP. Identifica la natura giuridico-amministrativa dell&apos;atto di programmazione e permette l&apos;aggregazione statistica dei dati e il monitoraggio a livello nazionale, facilitando il confronto tra programmi simili.</rdfs:comment>
        <rdfs:comment xml:lang="en">This is a subcategory of programming tools based on a predefined list (value domain) provided by the CUP system. It identifies the legal-administrative nature of the programming act and allows for statistical data aggregation and monitoring at the national level, facilitating comparisons between similar programs.</rdfs:comment>
        <rdfs:label xml:lang="en">Programming tool type</rdfs:label>
        <rdfs:label xml:lang="it">Tipo strumento di programmazione</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipologia_copertura_finanziaria -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipologia_copertura_finanziaria">
        <rdfs:comment xml:lang="it">Campo obbligatorio del corredo informativo che identifica le fonti economiche destinate al Progetto d&apos;investimento pubblico, permettendo l&apos;associazione di più valori (pubblici, privati o propri) tramite un sistema di inserimento multiplo. La sua compilazione è governata da logiche di esclusività dipendenti dal campo &quot;Partenariato Pubblico-Privato&quot;: se il partenariato è assente, sono ammesse solo fonti pubbliche; se è totale, solo fonti private; se è parziale, il sistema consente l&apos;integrazione di entrambe le tipologie di risorse. Funge da filtro di validazione per assicurare che la struttura finanziaria dichiarata sia coerente con la forma contrattuale dell&apos;investimento.</rdfs:comment>
        <rdfs:comment xml:lang="en">This mandatory field in the information package identifies the financial sources allocated to the public investment project, allowing the association of multiple values ​​(public, private, or own) through a multiple entry system. Its compilation is governed by exclusivity criteria based on the &quot;Public-Private Partnership&quot; field: if there is no partnership, only public sources are permitted; if there is a full partnership, only private sources are permitted; if there is a partial partnership, the system allows the integration of both types of resources. It serves as a validation filter to ensure that the declared financial structure is consistent with the contractual form of the investment.</rdfs:comment>
        <rdfs:label xml:lang="it">Tipologia copertura finanziaria</rdfs:label>
        <rdfs:label xml:lang="en">Type of financial coverage</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipologia_di_intervento -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Tipologia_di_intervento">
        <rdfs:comment xml:lang="it">Identifica con maggior livello di dettaglio la Natura di intervento e serve a specificare il metodo di attuazione. Ad esempio, nel caso di Natura 01 - Acquisto di beni, le Tipologie di intervento saranno &quot;Nuova fornitura&quot;, &quot;Manutenzione straordinaria&quot; o &quot;Altro&quot;).</rdfs:comment>
        <rdfs:comment xml:lang="en">It identifies the nature of the intervention in greater detail and serves to specify the implementation method. For example, in the case of Nature 01 - Purchase of goods, the types of intervention will be &quot;New supply&quot;, &quot;Extraordinary maintenance&quot;, or &quot;Other&quot;).</rdfs:comment>
        <rdfs:label xml:lang="it">Tipologia di intervento</rdfs:label>
        <rdfs:label xml:lang="en">Type of intervention</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Unità_organizzativa -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Unità_organizzativa">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/COV/hasSupportUnit"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Soggetto_accreditato_sistema_cup"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Service, Office, Management, Department of the Entity responsible for the project to which the reference user who interacts with the CUP System belongs.</rdfs:comment>
        <rdfs:comment xml:lang="it">Servizio, Ufficio, Direzione, Dipartimento del Soggetto responsabile del progetto cui appartiene l’utente di riferimento che interagisce con il Sistema CUP.</rdfs:comment>
        <rdfs:label xml:lang="en">Organizational unit</rdfs:label>
        <rdfs:label xml:lang="it">Unità organizzativa</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Utente_richiedente_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Utente_richiedente_cup">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Utente_sistema_cup"/>
        <rdfs:comment xml:lang="en">A natural person, unchangeable over time, who has registered in the system as a generating user and has requested a CUP. This person may be a Responsible Entity (Controller Entity) or a Concentrator Entity.</rdfs:comment>
        <rdfs:comment xml:lang="it">Persona fisica, immutabile nel tempo, che si è registrata al sistema come utente generatore e che ha richiesto il CUP. Può far capo ad un Soggetto responsabile (Soggetto Titolare) o ad un Soggetto concentratore.</rdfs:comment>
        <rdfs:label xml:lang="en">User requesting cup</rdfs:label>
        <rdfs:label xml:lang="it">Utente richiedente cup</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Utente_riferimento_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Utente_riferimento_cup">
        <rdfs:subClassOf rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Utente_sistema_cup"/>
        <rdfs:comment xml:lang="en">A natural person, variable over time, who has registered in the system as a generator user and who interacts with the CUP system for information or to maintain the information set of active projects. This person reports to the Responsible Entity (Controller Entity).</rdfs:comment>
        <rdfs:comment xml:lang="it">Persona fisica, variabile nel tempo, che si è registrata al sistema come utente generatore e che interagisce con il sistema CUP per informazioni o per la manutenzione del corredo informativo di progetti attivi. Fa capo al Soggetto responsabile (Soggetto Titolare).</rdfs:comment>
        <rdfs:label xml:lang="en">User reference cup</rdfs:label>
        <rdfs:label xml:lang="it">Utente riferimento cup</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Utente_sistema_cup -->

    <owl:Class rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Utente_sistema_cup">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_atto_autorizzazione_cup"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/COV/holdEmployment"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Unità_organizzativa"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/CPV/Alive"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/italia/onto/SM/hasOnlineContactPoint"/>
                        <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                        <owl:onClass rdf:resource="https://w3id.org/italia/onto/COV/OnlineContactPoint"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/italia/onto/SM/hasOnlineContactPoint"/>
                        <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                        <owl:onClass rdf:resource="https://w3id.org/italia/onto/COV/OnlineContactPoint"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A natural person who, following an accreditation procedure, interacts with the CUP system. They can register as a &quot;generator&quot; if, in addition to querying the database, they are interested in requesting codes and performing related operations, or as a &quot;reader&quot; if they only need to view the contents of the system&apos;s database.</rdfs:comment>
        <rdfs:comment xml:lang="it">Persona fisica che, in seguito ad una procedura di accreditamento, interagisce con il sistema CUP. Può accreditarsi come “generatore“, se, oltre ad interrogare la banca dati, è interessato a richiedere codici ed effettuare le relative operazioni collegate, o come “lettore“, se ha solo l’esigenza di visualizzare il contenuto della banca dati del sistema.</rdfs:comment>
        <rdfs:label xml:lang="en">Cup system user</rdfs:label>
        <rdfs:label xml:lang="it">Utente sistema cup</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/italia/onto/ADMS/Project -->

    <owl:Class rdf:about="https://w3id.org/italia/onto/ADMS/Project"/>
    


    <!-- https://w3id.org/italia/onto/ADMS/SemanticAssetDistribution -->

    <owl:Class rdf:about="https://w3id.org/italia/onto/ADMS/SemanticAssetDistribution"/>
    


    <!-- https://w3id.org/italia/onto/CLV/Address -->

    <owl:Class rdf:about="https://w3id.org/italia/onto/CLV/Address"/>
    


    <!-- https://w3id.org/italia/onto/COV/OnlineContactPoint -->

    <owl:Class rdf:about="https://w3id.org/italia/onto/COV/OnlineContactPoint"/>
    


    <!-- https://w3id.org/italia/onto/COV/Organization -->

    <owl:Class rdf:about="https://w3id.org/italia/onto/COV/Organization"/>
    


    <!-- https://w3id.org/italia/onto/COV/PublicOrganization -->

    <owl:Class rdf:about="https://w3id.org/italia/onto/COV/PublicOrganization"/>
    


    <!-- https://w3id.org/italia/onto/CPV/Alive -->

    <owl:Class rdf:about="https://w3id.org/italia/onto/CPV/Alive"/>
    


    <!-- https://w3id.org/italia/onto/TI/TimeIndexedEvent -->

    <owl:Class rdf:about="https://w3id.org/italia/onto/TI/TimeIndexedEvent"/>
    


    <!-- https://w3id.org/italia/onto/l0/Agent -->

    <owl:Class rdf:about="https://w3id.org/italia/onto/l0/Agent">
        <owl:disjointWith>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
            </owl:Restriction>
        </owl:disjointWith>
    </owl:Class>
    


    <!-- https://w3id.org/italia/onto/l0/Sequence -->

    <owl:Class rdf:about="https://w3id.org/italia/onto/l0/Sequence"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_di_beni -->

    <owl:NamedIndividual rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_di_beni">
        <rdfs:label xml:lang="it">acquisto di beni</rdfs:label>
        <rdfs:label xml:lang="en">purchase of goods</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_o_realizzazione_corso_di_formazione -->

    <owl:NamedIndividual rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_o_realizzazione_corso_di_formazione">
        <rdfs:label xml:lang="it">acquisto o realizzazione corso di formazione</rdfs:label>
        <rdfs:label xml:lang="en">purchase or completion of a training course</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_o_realizzazione_di_servizi -->

    <owl:NamedIndividual rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_o_realizzazione_di_servizi">
        <rdfs:label xml:lang="it">acquisto o realizzazione di servizi</rdfs:label>
        <rdfs:label xml:lang="en">purchase or provision of services</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_o_realizzazione_progetto_di_ricerca -->

    <owl:NamedIndividual rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_o_realizzazione_progetto_di_ricerca">
        <rdfs:label xml:lang="it">acquisto o realizzazione progetto di ricerca</rdfs:label>
        <rdfs:label xml:lang="en">purchase or implementation of research project</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_o_realizzazione_studio_o_progettazione -->

    <owl:NamedIndividual rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/acquisto_o_realizzazione_studio_o_progettazione">
        <rdfs:label xml:lang="it">acquisto o realizzazione studio o progettazione</rdfs:label>
        <rdfs:label xml:lang="en">purchase or implementation of study or design</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/concessione_di_contributi_ad_altri_soggetti -->

    <owl:NamedIndividual rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/concessione_di_contributi_ad_altri_soggetti">
        <rdfs:label xml:lang="it">concessione di contributi ad altri soggetti</rdfs:label>
        <rdfs:label xml:lang="en">granting of contributions to other entities</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/concessione_di_incentivi_ad_unità_produttive -->

    <owl:NamedIndividual rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/concessione_di_incentivi_ad_unità_produttive">
        <rdfs:label xml:lang="it">concessione di incentivi ad unità produttive</rdfs:label>
        <rdfs:label xml:lang="en">granting incentives to production units</rdfs:label>
    </owl:NamedIndividual>
    


