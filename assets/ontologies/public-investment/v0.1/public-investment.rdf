    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/asserisce_atto -->

    <owl:ObjectProperty rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/asserisce_atto">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/italia/onto/l0/Agent"/>
                    <owl:Restriction>
                        <owl:onProperty>
                            <rdf:Description>
                                <owl:inverseOf rdf:resource="https://w3id.org/italia/onto/RO/holdsRoleInTime"/>
                            </rdf:Description>
                        </owl:onProperty>
                        <owl:someValuesFrom rdf:resource="https://w3id.org/italia/onto/l0/Agent"/>
                    </owl:Restriction>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/Atto"/>
        <rdfs:label xml:lang="it">asserisce atto</rdfs:label>
        <rdfs:label xml:lang="en">asserts act</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_area_intervento -->

