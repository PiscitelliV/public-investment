        <owl:versionIRI rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/1.0"/>
        <dc:description rdf:resource="https://raw.githubusercontent.com/PCM-DIPE/public-investment/main/assets/ontologies/public-investment/latest/public-investment-atto.png"/>
        <dc:description rdf:resource="https://raw.githubusercontent.com/PCM-DIPE/public-investment/main/assets/ontologies/public-investment/latest/public-investment-cup.png"/>
        <dc:description rdf:resource="https://raw.githubusercontent.com/PCM-DIPE/public-investment/main/assets/ontologies/public-investment/latest/public-investment-intervento.png"/>
        <dc:description rdf:resource="https://raw.githubusercontent.com/PCM-DIPE/public-investment/main/assets/ontologies/public-investment/latest/public-investment-natura-intervento.png"/>
        <dc:description rdf:resource="https://raw.githubusercontent.com/PCM-DIPE/public-investment/main/assets/ontologies/public-investment/latest/public-investment-progetto.png"/>
        <dc:description rdf:resource="https://raw.githubusercontent.com/PCM-DIPE/public-investment/main/assets/ontologies/public-investment/latest/public-investment-relazioni-intervento.png"/>
        <dc:description rdf:resource="https://raw.githubusercontent.com/PCM-DIPE/public-investment/main/assets/ontologies/public-investment/latest/public-investment-soggetto.png"/>
        <dc:description rdf:resource="https://raw.githubusercontent.com/PCM-DIPE/public-investment/main/assets/ontologies/public-investment/latest/public-investment-tipizzazione-data-property.png"/>
        <dc:description>Atto.</dc:description>
        <dc:description>CUP.</dc:description>
        <dc:description>Intervento.</dc:description>
        <dc:description>Natura di intervento.</dc:description>
        <dc:description>Progetto.</dc:description>
        <dc:description>Relazioni intervento.</dc:description>
        <dc:description>Soggetto.</dc:description>
        <dc:description>Tipizzazione data property.</dc:description>
        <dct:accrualPeriodicity rdf:resource="http://publications.europa.eu/resource/authority/frequency/IRREG"/>
        <dct:creator rdf:resource="https://w3id.org/italia/data/public-organization/ISTAT"/>
        <dct:creator rdf:resource="https://w3id.org/italia/data/public-organization/PCM-DIPE"/>
        <dct:description xml:lang="it">L’ontologia è il prodotto dell&apos;analisi semantica del Codice Unico di Progetto (CUP) e del patrimonio informativo del portale OpenCUP. È sviluppata dal Dipartimento per la programmazione e il coordinamento della politica economica (DIPE) della Presidenza del Consiglio dei Ministri, con la semantic stewardship dell&apos;ISTAT e in coordinamento con il Dipartimento per la Trasformazione Digitale (DTD), nell&apos;ambito dell&apos;Impegno C6 del 6° Piano d&apos;Azione Nazionale per il Governo Aperto (OGP) 2024–2026. È allineata con le ontologie CORE della rete semantica del Catalogo Nazionale dei dati (schema.gov.it).</dct:description>
        <dct:description xml:lang="en">This ontology results from the semantic analysis of the Unique Project Code (CUP) and the information assets of the OpenCUP portal. It has been developed by the Department for Programming and Coordination of Economic Policy (DIPE) of the Presidency of the Council of Ministers, with semantic stewardship by ISTAT and in coordination with the Department for Digital Transformation (DTD), within Commitment C6 of the 6th National Action Plan for the Open Government Partnership (OGP) 2024–2026. It is aligned with the CORE ontologies of the National Data Catalogue semantic network (schema.gov.it).</dct:description>
        <dct:identifier>https://w3id.org/italia/PublicInvestment/onto/PublicInvestment</dct:identifier>
        <dct:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-07-07</dct:issued>
        <dct:language rdf:resource="http://publications.europa.eu/resource/authority/language/ENG"/>
        <dct:language rdf:resource="http://publications.europa.eu/resource/authority/language/ITA"/>
        <dct:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-07-07</dct:modified>
        <dct:publisher rdf:resource="https://w3id.org/italia/data/public-organization/PCM-DIPE"/>
        <dct:rightsHolder rdf:resource="https://w3id.org/italia/data/public-organization/PCM-DIPE"/>
        <dct:subject rdf:resource="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment"/>
        <dct:temporal>Dal 2026</dct:temporal>
        <dct:title xml:lang="it">Ontologia degli Investimenti Pubblici</dct:title>
        <dct:title xml:lang="en">Public Investment Ontology</dct:title>
        <rdfs:comment xml:lang="it">L’ontologia è il prodotto dell&apos;analisi semantica del Codice Unico di Progetto (CUP) e del patrimonio informativo del portale OpenCUP. È sviluppata dal Dipartimento per la programmazione e il coordinamento della politica economica (DIPE) della Presidenza del Consiglio dei Ministri, con la semantic stewardship dell&apos;ISTAT e in coordinamento con il Dipartimento per la Trasformazione Digitale (DTD), nell&apos;ambito dell&apos;Impegno C6 del 6° Piano d&apos;Azione Nazionale per il Governo Aperto (OGP) 2024–2026. È allineata con le ontologie CORE della rete semantica del Catalogo Nazionale dei dati (schema.gov.it).</rdfs:comment>
        <rdfs:comment xml:lang="en">This ontology results from the semantic analysis of the Unique Project Code (CUP) and the information assets of the OpenCUP portal. It has been developed by the Department for Programming and Coordination of Economic Policy (DIPE) of the Presidency of the Council of Ministers, with semantic stewardship by ISTAT and in coordination with the Department for Digital Transformation (DTD), within Commitment C6 of the 6th National Action Plan for the Open Government Partnership (OGP) 2024–2026. It is aligned with the CORE ontologies of the National Data Catalogue semantic network (schema.gov.it).</rdfs:comment>
        <rdfs:label xml:lang="it">Ontologia degli Investimenti Pubblici</rdfs:label>
        <rdfs:label xml:lang="en">Public Investment Ontology.</rdfs:label>
        <owl:versionInfo xml:lang="en">Version 1.0</owl:versionInfo>
        <owl:versionInfo xml:lang="it">Versione 1.0</owl:versionInfo>
