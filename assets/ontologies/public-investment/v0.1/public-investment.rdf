        <admsapit:prefix>pi</admsapit:prefix>
        <admsapit:semanticAssetInUse rdf:resource="https://w3id.org/italia/data/project/NDC"/>
        <admsapit:status>catalogued</admsapit:status>
        <admsapit:status>published</admsapit:status>
        <admsapit:target>Pubbliche Amministrazioni</admsapit:target>
        <admsapit:type rdf:resource="https://w3id.org/italia/onto/ADMS/DomainOntology"/>
