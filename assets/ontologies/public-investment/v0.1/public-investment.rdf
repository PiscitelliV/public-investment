    <owl:ObjectProperty rdf:about="https://w3id.org/italia/PublicInvestment/onto/PublicInvestment/ha_atto_delega_richiesta_cup">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
