        <dcat:keyword xml:lang="it">Investimenti Pubblici</dcat:keyword>
        <dcat:keyword xml:lang="en">OpenCUP</dcat:keyword>
        <dcat:keyword xml:lang="it">OpenCUP</dcat:keyword>
